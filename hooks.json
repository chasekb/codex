{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash /Users/bernardchase/.codex/hooks/TaskStart",
            "timeout": 30,
            "statusMessage": "Loading global workflow state"
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash /Users/bernardchase/.codex/hooks/TaskResume",
            "timeout": 30,
            "statusMessage": "Restoring global workflow state"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash /Users/bernardchase/.codex/hooks/PreToolUse",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash /Users/bernardchase/.codex/hooks/PostToolUse",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash /Users/bernardchase/.codex/hooks/UserPromptSubmit",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash /Users/bernardchase/.codex/hooks/TaskComplete",
            "timeout": 45
          }
        ]
      }
    ]
  }
}
