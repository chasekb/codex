# Global safety defaults for Codex command approvals.
# Most restrictive matching decision wins: forbidden > prompt > allow.

# Never permit destructive recursive delete.
prefix_rule(
  pattern = ["rm", "-rf"],
  decision = "forbidden",
  justification = "Use safer scoped deletion and explicit review instead of rm -rf.",
  match = ["rm -rf /tmp/test"],
)

# Require prompt for branch/remote mutations.
prefix_rule(
  pattern = ["git", "push"],
  decision = "prompt",
  justification = "Pushing branches should require explicit confirmation.",
  match = ["git push origin main"],
)

# Require prompt before publishing npm packages.
prefix_rule(
  pattern = ["npm", "publish"],
  decision = "prompt",
  justification = "Package publishing is high impact.",
  match = ["npm publish"],
)

# Read-only tool allowances.
prefix_rule(pattern=["tmux", "capture-pane"], decision="allow")

# Common shell inspection tools.
prefix_rule(pattern=["pwd"], decision="allow")
prefix_rule(pattern=["ls"], decision="allow")
prefix_rule(pattern=["cat"], decision="allow")
prefix_rule(pattern=["sed"], decision="allow")
prefix_rule(pattern=["grep"], decision="allow")
prefix_rule(pattern=["awk"], decision="allow")
prefix_rule(pattern=["cut"], decision="allow")
prefix_rule(pattern=["join"], decision="allow")
prefix_rule(pattern=["paste"], decision="allow")
prefix_rule(pattern=["tr"], decision="allow")
prefix_rule(pattern=["head"], decision="allow")
prefix_rule(pattern=["tail"], decision="allow")
prefix_rule(pattern=["find"], decision="allow")
prefix_rule(pattern=["rg"], decision="allow")
prefix_rule(pattern=["wc"], decision="allow")
prefix_rule(pattern=["which"], decision="allow")
prefix_rule(pattern=["type"], decision="allow")
prefix_rule(pattern=["env"], decision="allow")
prefix_rule(pattern=["printenv"], decision="allow")
prefix_rule(pattern=["uname"], decision="allow")
prefix_rule(pattern=["date"], decision="allow")
prefix_rule(pattern=["sort"], decision="allow")
prefix_rule(pattern=["uniq"], decision="allow")
prefix_rule(pattern=["stat"], decision="allow")
prefix_rule(pattern=["file"], decision="allow")
prefix_rule(pattern=["tree"], decision="allow")

# Second-tier utility commands.
prefix_rule(pattern=["python", "--version"], decision="allow")
prefix_rule(pattern=["python3", "--version"], decision="allow")
prefix_rule(pattern=["node", "--version"], decision="allow")
prefix_rule(pattern=["npm", "--version"], decision="allow")
prefix_rule(pattern=["git", "--version"], decision="allow")
prefix_rule(pattern=["gh", "--version"], decision="allow")
prefix_rule(pattern=["podman", "--version"], decision="allow")
prefix_rule(pattern=["docker", "--version"], decision="allow")

# Third-tier archive and data inspection.
prefix_rule(pattern=["tar"], decision="allow")
prefix_rule(pattern=["unzip"], decision="allow")
prefix_rule(pattern=["zipinfo"], decision="allow")
prefix_rule(pattern=["gzip"], decision="allow")
prefix_rule(pattern=["jq"], decision="allow")
prefix_rule(pattern=["yq"], decision="allow")
prefix_rule(pattern=["sha256sum"], decision="allow")
prefix_rule(pattern=["md5sum"], decision="allow")
prefix_rule(pattern=["cksum"], decision="allow")

# Fourth-tier process and disk inspection.
prefix_rule(pattern=["ps"], decision="allow")
prefix_rule(pattern=["top"], decision="allow")
prefix_rule(pattern=["htop"], decision="allow")
prefix_rule(pattern=["pstree"], decision="allow")
prefix_rule(pattern=["lsof"], decision="allow")
prefix_rule(pattern=["df"], decision="allow")
prefix_rule(pattern=["du"], decision="allow")
prefix_rule(pattern=["free"], decision="allow")
prefix_rule(pattern=["uptime"], decision="allow")
prefix_rule(pattern=["whoami"], decision="allow")
prefix_rule(pattern=["id"], decision="allow")

# Fifth-tier package-manager inspection.
prefix_rule(pattern=["npm", "ls"], decision="allow")
prefix_rule(pattern=["npm", "view"], decision="allow")
prefix_rule(pattern=["npm", "outdated"], decision="allow")
prefix_rule(pattern=["pip", "list"], decision="allow")
prefix_rule(pattern=["pip", "show"], decision="allow")
prefix_rule(pattern=["pip", "freeze"], decision="allow")
prefix_rule(pattern=["brew", "list"], decision="allow")
prefix_rule(pattern=["brew", "info"], decision="allow")
prefix_rule(pattern=["brew", "outdated"], decision="allow")
prefix_rule(pattern=["cargo", "tree"], decision="allow")
prefix_rule(pattern=["cargo", "metadata"], decision="allow")
prefix_rule(pattern=["rustup", "show"], decision="allow")

# Sixth-tier package and index lookup.
prefix_rule(pattern=["npm", "explain"], decision="allow")
prefix_rule(pattern=["npm", "search"], decision="allow")
prefix_rule(pattern=["pip", "index", "versions"], decision="allow")
prefix_rule(pattern=["pip", "index", "search"], decision="allow")
prefix_rule(pattern=["brew", "search"], decision="allow")
prefix_rule(pattern=["cargo", "search"], decision="allow")
prefix_rule(pattern=["cargo", "info"], decision="allow")

# Podman inspection only.
prefix_rule(pattern=["podman", "ps"], decision="allow")
prefix_rule(pattern=["podman", "images"], decision="allow")
prefix_rule(pattern=["podman", "logs"], decision="allow")
prefix_rule(pattern=["podman", "inspect"], decision="allow")

# GitHub read-only operations only.
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "run", "list"], decision="allow")
prefix_rule(pattern=["gh", "run", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "view"], decision="allow")
prefix_rule(pattern=["gh", "pr", "status"], decision="allow")
prefix_rule(pattern=["gh", "repo", "view"], decision="allow")

# Git read-only operations only.
prefix_rule(pattern=["git", "status"], decision="allow")
prefix_rule(pattern=["git", "diff"], decision="allow")
prefix_rule(pattern=["git", "log"], decision="allow")
prefix_rule(pattern=["git", "show"], decision="allow")
prefix_rule(pattern=["git", "branch"], decision="allow")
prefix_rule(pattern=["git", "remote"], decision="allow")
prefix_rule(pattern=["git", "rev-parse"], decision="allow")
prefix_rule(pattern=["git", "ls-files"], decision="allow")
