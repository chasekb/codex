#!/usr/bin/env bash
set -euo pipefail

hook_name="${1:-unknown}"
log_file="outputs/hook-events.log"
mkdir -p "$(dirname "$log_file")"

payload="$(cat)"

python3 - <<'PY' "$hook_name" "$payload" "$log_file"
import json
import sys
from datetime import datetime, timezone

hook_name = sys.argv[1]
raw = sys.argv[2]
log_file = sys.argv[3]

try:
    data = json.loads(raw) if raw else {}
except Exception:
    data = {}

pre = data.get("preToolUse") if isinstance(data.get("preToolUse"), dict) else {}
post = data.get("postToolUse") if isinstance(data.get("postToolUse"), dict) else {}

tool_name = (
    pre.get("toolName")
    or post.get("toolName")
    or data.get("toolName")
    or data.get("tool_name")
    or ((data.get("tool") or {}).get("name") if isinstance(data.get("tool"), dict) else None)
    or ""
)

tool_input = (
    pre.get("parameters")
    or pre.get("toolInput")
    or pre.get("arguments")
    or post.get("parameters")
    or post.get("toolInput")
    or post.get("arguments")
    or data.get("parameters")
    or data.get("toolInput")
    or data.get("tool_input")
    or data.get("arguments")
    or {}
)

if isinstance(tool_input, str):
    try:
        parsed = json.loads(tool_input)
        if isinstance(parsed, dict):
            tool_input = parsed
    except Exception:
        pass

paths = []
if isinstance(tool_input, dict):
    for key in (
        "path", "file_path", "target_file", "sourcePath", "destinationPath",
        "source_path", "destination_path", "filePath",
    ):
        v = tool_input.get(key)
        if isinstance(v, str) and v.strip():
            paths.append(v.strip())
    for key in ("paths", "files"):
        vv = tool_input.get(key)
        if isinstance(vv, list):
            paths.extend([x.strip() for x in vv if isinstance(x, str) and x.strip()])

entry = {
    "timestamp": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    "hook": hook_name,
    "tool": tool_name,
    "paths": sorted(set(paths)),
    "payload_keys": sorted(data.keys()) if isinstance(data, dict) else [],
}

with open(log_file, "a", encoding="utf-8") as f:
    f.write(json.dumps(entry, separators=(",", ":")) + "\n")
PY
