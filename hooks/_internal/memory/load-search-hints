#!/usr/bin/env python3
import json
import re
import sys
from datetime import datetime, timezone
from pathlib import Path


def tokenize(value):
    if not isinstance(value, str):
        return []
    return [part for part in re.split(r"[^a-z0-9]+", value.lower()) if len(part) > 2]


def parse_ts(value):
    try:
        return datetime.fromisoformat(str(value).replace("Z", "+00:00"))
    except Exception:
        return None


def load_json(path, default):
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return default


def load_jsonl(path):
    records = []
    if not Path(path).is_file():
        return records
    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for raw in f:
            line = raw.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except Exception:
                continue
            if isinstance(obj, dict):
                records.append(obj)
    return records


def score_record(record, task_class, terms):
    tokens = set(tokenize(" ".join(
        [
            str(record.get("type", "")),
            str(record.get("scope", "")),
            str(record.get("source", "")),
            str(record.get("content_1line", "")),
            " ".join(record.get("tags", []) if isinstance(record.get("tags", []), list) else []),
        ]
    )))
    score = 0.0
    if task_class and task_class.lower() in tokens:
        score += 0.8
    if terms:
        score += sum(0.7 for term in terms if term in tokens)
    if "search" in tokens:
        score += 0.9
    if "provenance" in tokens:
        score += 0.7
    if "research" in tokens:
        score += 0.5
    if "pending" in tokens:
        score += 0.2
    ts = parse_ts(record.get("ts", ""))
    if ts:
        age_days = max(0, (datetime.now(timezone.utc) - ts).days)
        score += max(0.0, 0.5 - (age_days / 90.0))
    return score


def compact_record(record):
    return {
        "id": record.get("id", ""),
        "type": record.get("type", ""),
        "scope": record.get("scope", ""),
        "tags": record.get("tags", [])[:6] if isinstance(record.get("tags", []), list) else [],
        "content_1line": str(record.get("content_1line", ""))[:220],
        "source": record.get("source", ""),
        "confidence": record.get("confidence", 0.0),
        "ts": record.get("ts", ""),
    }


def add_pending_searches(session, results, max_items):
    pending = session.get("task", {}).get("pending_searches", [])
    if not isinstance(pending, list):
        pending = []
    for item in pending[:max_items]:
        if not isinstance(item, dict):
            continue
        results.append(
            {
                "kind": "pending_search",
                "tool_name": str(item.get("tool_name", "")),
                "query": str(item.get("query", ""))[:220],
            }
        )


def main():
    task_class = sys.argv[1] if len(sys.argv) > 1 else "general"
    keywords = sys.argv[2] if len(sys.argv) > 2 else ""
    max_chars = int(sys.argv[3]) if len(sys.argv) > 3 else 500
    max_results = int(sys.argv[4]) if len(sys.argv) > 4 else 6
    memory_root = Path(sys.argv[5]) if len(sys.argv) > 5 else Path("MCP/memory")

    session = load_json(memory_root / "session.json", {})
    facts = load_jsonl(memory_root / "facts.jsonl")
    decisions = load_jsonl(memory_root / "decisions.jsonl")
    terms = [term for term in tokenize(f"{task_class} {keywords}") if term]

    ranked = []
    for record in facts + decisions:
        if not isinstance(record, dict):
            continue
        tags = record.get("tags", [])
        if not isinstance(tags, list):
            tags = []
        content = str(record.get("content_1line", ""))
        if "search" not in {str(tag).lower() for tag in tags} and not content.lower().startswith("search"):
            continue
        score = score_record(record, task_class, terms)
        if score <= 0:
            continue
        candidate = compact_record(record)
        candidate["score"] = round(score, 4)
        ranked.append(candidate)

    ranked.sort(key=lambda item: (item.get("score", 0.0), item.get("ts", "")), reverse=True)

    results = []
    used_chars = 0
    add_pending_searches(session, results, max_results)
    used_chars += sum(len(json.dumps(item, separators=(",", ":"))) for item in results)

    seen = {(item.get("kind", ""), item.get("query", ""), item.get("tool_name", "")) for item in results}
    for record in ranked:
        compact = {
            "kind": "search_record",
            "id": record.get("id", ""),
            "scope": record.get("scope", ""),
            "source": record.get("source", ""),
            "tags": record.get("tags", []),
            "content_1line": record.get("content_1line", ""),
            "ts": record.get("ts", ""),
            "score": record.get("score", 0.0),
        }
        key = (compact["kind"], compact["content_1line"], compact["source"])
        if key in seen:
            continue
        encoded = json.dumps(compact, separators=(",", ":"))
        if len(results) >= max_results:
            break
        if used_chars + len(encoded) > max_chars:
            break
        seen.add(key)
        results.append(compact)
        used_chars += len(encoded)

    report = {
        "search_hints_loaded": len(results),
        "chars": used_chars,
        "results": results,
    }
    print(json.dumps(report, separators=(",", ":")))
    print(f"search_hints:metrics loaded={len(results)} chars={used_chars}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
