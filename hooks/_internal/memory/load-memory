#!/usr/bin/env bash
set -euo pipefail

task_class="${1:-general}"
keywords="${2:-}"
max_chars="${3:-500}"
max_results="${4:-6}"
memory_root="${5:-MCP/memory}"

session_file="$memory_root/session.json"
facts_file="$memory_root/facts.jsonl"
decisions_file="$memory_root/decisions.jsonl"

[[ -f "$session_file" ]] || { echo "memory:error missing_session"; exit 1; }
[[ -f "$facts_file" ]] || { echo "memory:error missing_facts"; exit 1; }
[[ -f "$decisions_file" ]] || { echo "memory:error missing_decisions"; exit 1; }

python3 - <<'PY' "$task_class" "$keywords" "$max_chars" "$max_results" "$session_file" "$facts_file" "$decisions_file"
import json
import re
import sys
from datetime import datetime

task_class, keywords, max_chars, max_results, session_file, facts_file, decisions_file = sys.argv[1:]
max_chars = int(max_chars)
max_results = int(max_results)


def tokenize(value):
    if not isinstance(value, str):
        return []
    return [part for part in re.split(r"[^a-z0-9]+", value.lower()) if len(part) > 1]


def normalize_text(value, limit=220):
    return " ".join(str(value).split())[:limit]


def normalize_list(values, max_items, limit=140):
    if not isinstance(values, list):
        return []
    out = []
    for item in values[:max_items]:
        item_text = normalize_text(item, limit)
        if item_text:
            out.append(item_text)
    return out


def session_focus_terms(session_task):
    values = [
        session_task.get("objective", ""),
        *session_task.get("constraints", []),
        *session_task.get("active_files", []),
        *session_task.get("latest_decisions", []),
        *session_task.get("blockers", []),
    ]
    terms = []
    for value in values:
        terms.extend(tokenize(str(value)))
    return {term for term in terms if len(term) > 1}

def safe_jsonl(path):
    out = []
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except Exception:
                continue
            if not obj.get("id"):
                continue
            out.append(obj)
    return out

def score_record(r):
    txt = (r.get("content_1line", "") + " " + " ".join(r.get("tags", []))).lower()
    score = 0.0
    if task_class and task_class in txt:
        score += 0.5
    if terms:
        score += sum(1 for t in terms if t in txt)
    score += float(r.get("confidence", 0.0))
    ts = r.get("ts", "")
    try:
        if ts:
            dt = datetime.fromisoformat(ts.replace("Z", "+00:00"))
            age_days = (datetime.now(dt.tzinfo) - dt).days
            score += max(0, 0.5 - age_days / 60.0)
    except Exception:
        pass
    return score

with open(session_file, "r", encoding="utf-8") as f:
    session = json.load(f)

records = safe_jsonl(facts_file) + safe_jsonl(decisions_file)
session_task = session.get("task", {}) if isinstance(session.get("task", {}), dict) else {}
terms = [t for t in tokenize(f"{task_class} {keywords}") if t]
terms.extend(sorted(session_focus_terms(session_task)))
ranked = sorted(records, key=score_record, reverse=True)

result = []
used_chars = 0

session_variants = [
    {
        "type": "session",
        "objective": normalize_text(session_task.get("objective", ""), 180),
        "constraints": normalize_list(session_task.get("constraints", []), 4, 120),
        "active_files": normalize_list(session_task.get("active_files", []), 6, 140),
        "latest_decisions": normalize_list(session_task.get("latest_decisions", []), 4, 140),
        "blockers": normalize_list(session_task.get("blockers", []), 4, 140),
    },
    {
        "type": "session",
        "objective": normalize_text(session_task.get("objective", ""), 180),
        "constraints": normalize_list(session_task.get("constraints", []), 4, 120),
        "active_files": normalize_list(session_task.get("active_files", []), 6, 140),
        "latest_decisions": normalize_list(session_task.get("latest_decisions", []), 4, 140),
        "blockers": [],
    },
    {
        "type": "session",
        "objective": normalize_text(session_task.get("objective", ""), 180),
        "constraints": normalize_list(session_task.get("constraints", []), 4, 120),
        "active_files": normalize_list(session_task.get("active_files", []), 6, 140),
        "latest_decisions": [],
        "blockers": [],
    },
    {
        "type": "session",
        "objective": normalize_text(session_task.get("objective", ""), 180),
        "constraints": normalize_list(session_task.get("constraints", []), 3, 100),
        "active_files": normalize_list(session_task.get("active_files", []), 4, 110),
        "latest_decisions": [],
        "blockers": [],
    },
]

for session_blob in session_variants:
    session_str = json.dumps(session_blob, separators=(",", ":"))
    if len(session_str) <= max_chars:
        result.append(session_blob)
        used_chars += len(session_str)
        break

seen = set()
for r in ranked:
    compact = {
        "id": r.get("id", ""),
        "type": r.get("type", ""),
        "tags": r.get("tags", [])[:5],
        "content_1line": str(r.get("content_1line", ""))[:220],
        "confidence": r.get("confidence", 0.0),
        "ts": r.get("ts", ""),
    }
    key = (compact["type"], compact["content_1line"])
    if key in seen:
        continue
    encoded = json.dumps(compact, separators=(",", ":"))
    if len(result) >= max_results:
        break
    if used_chars + len(encoded) > max_chars:
        break
    seen.add(key)
    result.append(compact)
    used_chars += len(encoded)

print(json.dumps({
    "memory_loaded": len(result),
    "chars": used_chars,
    "results": result
}, separators=(",", ":")))

print(f"memory:metrics loaded={len(result)} chars={used_chars}")
PY
