#!/usr/bin/env python3
import json
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path


def tokenize(value):
    if not isinstance(value, str):
        return []
    return [part for part in re.split(r"[^a-z0-9]+", value.lower()) if len(part) > 2]


def parse_ts(value):
    try:
        return datetime.fromisoformat(str(value).replace("Z", "+00:00"))
    except Exception:
        return None


def load_lines(*paths):
    records = []
    for path in paths:
        if not Path(path).is_file():
            continue
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            for raw in f:
                line = raw.strip()
                if line:
                    records.append((path, line))
    return records


def parse_line(path, line):
    record = {
        "source_file": str(path),
        "line": line[:280],
        "timestamp": "",
        "hook": "",
        "stage": "",
        "status": "",
        "tool": "",
        "rc": "",
        "details": "",
    }
    parts = line.split()
    if parts:
        ts = parts[0]
        if "T" in ts:
            record["timestamp"] = ts
    for part in parts[1:]:
        if "=" not in part:
            continue
        key, value = part.split("=", 1)
        if key == "hook":
            record["hook"] = value
        elif key == "stage":
            record["stage"] = value
        elif key == "status":
            record["status"] = value
        elif key == "tool":
            record["tool"] = value
        elif key == "rc":
            record["rc"] = value
        elif key == "details":
            record["details"] = value
    return record


def score_entry(entry, task_class, terms):
    tokens = set(tokenize(" ".join(
        [
            entry.get("hook", ""),
            entry.get("stage", ""),
            entry.get("status", ""),
            entry.get("tool", ""),
            entry.get("rc", ""),
            entry.get("details", ""),
            entry.get("line", ""),
        ]
    )))
    score = 0.0
    if task_class and task_class.lower() in tokens:
        score += 1.0
    if terms:
        score += sum(0.8 for term in terms if term in tokens)
    if entry.get("rc"):
        score += 0.6
        if entry.get("rc") != "0":
            score += 0.4
    if entry.get("status") in {"failed", "error", "warning"}:
        score += 1.0
    if "fallback" in tokens:
        score += 0.5
    if entry.get("hook") in {"TaskStart", "TaskResume", "PreToolUse", "PostToolUse", "TaskComplete"}:
        score += 0.4
    ts = parse_ts(entry.get("timestamp", ""))
    if ts:
        age_days = max(0, (datetime.now(timezone.utc) - ts).days)
        score += max(0.0, 0.7 - (age_days / 90.0))
    return score


def compact_entry(entry):
    summary = entry.get("line", "")
    if len(summary) > 220:
        summary = summary[:217] + "..."
    return {
        "timestamp": entry.get("timestamp", ""),
        "hook": entry.get("hook", ""),
        "stage": entry.get("stage", ""),
        "status": entry.get("status", ""),
        "tool": entry.get("tool", ""),
        "rc": entry.get("rc", ""),
        "summary": summary,
        "source_file": entry.get("source_file", ""),
    }


def main():
    task_class = sys.argv[1] if len(sys.argv) > 1 else "general"
    keywords = sys.argv[2] if len(sys.argv) > 2 else ""
    max_chars = int(sys.argv[3]) if len(sys.argv) > 3 else 500
    max_results = int(sys.argv[4]) if len(sys.argv) > 4 else 6
    errors_path = Path(sys.argv[5]) if len(sys.argv) > 5 else Path("outputs/hook-errors.log")
    compat_path = Path(sys.argv[6]) if len(sys.argv) > 6 else Path("outputs/hook-file-error.log")

    terms = [term for term in tokenize(f"{task_class} {keywords}") if term]
    records = []
    for path, line in load_lines(errors_path, compat_path):
        parsed = parse_line(path, line)
        score = score_entry(parsed, task_class, terms)
        if score <= 0:
            continue
        parsed["score"] = round(score, 4)
        records.append(parsed)

    records.sort(key=lambda item: (item.get("score", 0.0), item.get("timestamp", "")), reverse=True)

    result = []
    used_chars = 0
    for record in records:
        compact = compact_entry(record)
        encoded = json.dumps(compact, separators=(",", ":"))
        if len(result) >= max_results:
            break
        if used_chars + len(encoded) > max_chars:
            break
        result.append(compact)
        used_chars += len(encoded)

    report = {
        "failure_history_loaded": len(result),
        "chars": used_chars,
        "results": result,
    }
    print(json.dumps(report, separators=(",", ":")))
    print(f"failure:metrics loaded={len(result)} chars={used_chars}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
