#!/usr/bin/env python3
import json
import os
import re
import sys
from datetime import datetime, timezone
from pathlib import Path


def tokenize(value):
    if not isinstance(value, str):
        return []
    return [part for part in re.split(r"[^a-z0-9]+", value.lower()) if len(part) > 2]


def parse_ts(value):
    try:
        return datetime.fromisoformat(str(value).replace("Z", "+00:00"))
    except Exception:
        return None


def load_markdown_entries(path):
    if not Path(path).is_file():
        return []

    entries = []
    current = None
    with open(path, "r", encoding="utf-8") as f:
        for raw in f:
            line = raw.rstrip("\n")
            if line.startswith("## ["):
                if current:
                    entries.append(current)
                current = {
                    "file": str(path),
                    "header": line.strip(),
                    "lines": [],
                }
                continue
            if current is not None:
                current["lines"].append(line)
    if current:
        entries.append(current)
    return entries


def parse_entry(entry):
    header = entry.get("header", "")
    lines = entry.get("lines", [])
    m = re.match(r"^## \[([^\]]+)\]\s*(.*)$", header)
    entry_id = m.group(1).strip() if m else ""
    category = m.group(2).strip() if m else ""

    data = {
        "id": entry_id,
        "category": category,
        "status": "",
        "priority": "medium",
        "area": "",
        "summary": "",
        "details": "",
        "suggested_action": "",
        "pattern_key": "",
        "tags": [],
        "source": "",
        "skill_action": "",
        "skill_owner": "",
        "logged": "",
        "source_file": entry.get("file", ""),
    }

    section = ""
    section_lines = {"Summary": [], "Details": [], "Suggested Action": []}
    for raw in lines:
        line = raw.strip()
        if line == "### Summary":
            section = "Summary"
            continue
        if line == "### Details":
            section = "Details"
            continue
        if line == "### Suggested Action":
            section = "Suggested Action"
            continue
        if line == "### Metadata":
            section = "Metadata"
            continue
        if line.startswith("**Logged**:"):
            data["logged"] = line.split(":", 1)[1].strip()
            continue
        if line.startswith("**Priority**:"):
            data["priority"] = line.split(":", 1)[1].strip().lower()
            continue
        if line.startswith("**Status**:"):
            data["status"] = line.split(":", 1)[1].strip().lower()
            continue
        if line.startswith("**Area**:"):
            data["area"] = line.split(":", 1)[1].strip().lower()
            continue
        if section == "Metadata":
            meta_line = line.lstrip("- ").strip()
            if meta_line.startswith("Source:"):
                data["source"] = meta_line.split(":", 1)[1].strip()
            elif meta_line.startswith("Tags:"):
                data["tags"] = [part.strip().lower() for part in meta_line.split(":", 1)[1].split(",") if part.strip()]
            elif meta_line.startswith("Pattern-Key:"):
                data["pattern_key"] = meta_line.split(":", 1)[1].strip().lower()
            elif meta_line.startswith("Skill-Action:"):
                data["skill_action"] = meta_line.split(":", 1)[1].strip().lower()
            elif meta_line.startswith("Skill-Owner:"):
                data["skill_owner"] = meta_line.split(":", 1)[1].strip().lower()
        elif section in section_lines and line:
            section_lines[section].append(line)

    data["summary"] = " ".join(section_lines["Summary"]).strip()
    data["details"] = " ".join(section_lines["Details"]).strip()
    data["suggested_action"] = " ".join(section_lines["Suggested Action"]).strip()
    return data


def score_entry(entry, task_class, terms):
    text = " ".join(
        [
            entry.get("id", ""),
            entry.get("category", ""),
            entry.get("status", ""),
            entry.get("priority", ""),
            entry.get("area", ""),
            entry.get("summary", ""),
            entry.get("details", ""),
            entry.get("suggested_action", ""),
            entry.get("pattern_key", ""),
            " ".join(entry.get("tags", []) or []),
        ]
    ).lower()
    tokens = set(tokenize(text))
    score = 0.0

    if task_class and task_class.lower() in tokens:
        score += 1.0
    if terms:
        score += sum(0.9 for term in terms if term in tokens)
    if entry.get("pattern_key"):
        pattern_tokens = set(tokenize(entry["pattern_key"]))
        score += sum(0.6 for term in terms if term in pattern_tokens)

    status = entry.get("status", "")
    if status in {"promoted", "resolved"}:
        score += 1.2
    elif status == "in_progress":
        score += 0.4
    elif status == "pending":
        score += 0.1

    priority = entry.get("priority", "medium")
    if priority == "critical":
        score += 1.0
    elif priority == "high":
        score += 0.8
    elif priority == "medium":
        score += 0.4

    logged = parse_ts(entry.get("logged", ""))
    if logged:
        age_days = (datetime.now(timezone.utc) - logged).days
        score += max(0.0, 0.7 - (age_days / 120.0))

    return score


def compact_entry(entry):
    return {
        "id": entry.get("id", ""),
        "category": entry.get("category", ""),
        "status": entry.get("status", ""),
        "priority": entry.get("priority", ""),
        "area": entry.get("area", ""),
        "summary": entry.get("summary", "")[:220],
        "suggested_action": entry.get("suggested_action", "")[:180],
        "pattern_key": entry.get("pattern_key", "")[:120],
        "skill_action": entry.get("skill_action", "")[:120],
        "skill_owner": entry.get("skill_owner", "")[:120],
        "source_file": entry.get("source_file", ""),
        "logged": entry.get("logged", ""),
    }


def main():
    task_class = sys.argv[1] if len(sys.argv) > 1 else "general"
    keywords = sys.argv[2] if len(sys.argv) > 2 else ""
    max_chars = int(sys.argv[3]) if len(sys.argv) > 3 else 500
    max_results = int(sys.argv[4]) if len(sys.argv) > 4 else 6
    learnings_root = Path(sys.argv[5]) if len(sys.argv) > 5 else Path(".learnings")

    files = [
        learnings_root / "LEARNINGS.md",
        learnings_root / "ERRORS.md",
        learnings_root / "FEATURE_REQUESTS.md",
    ]
    terms = [term for term in tokenize(f"{task_class} {keywords}") if term]

    records = []
    for file_path in files:
        for raw_entry in load_markdown_entries(file_path):
            parsed = parse_entry(raw_entry)
            parsed["source_file"] = str(file_path)
            score = score_entry(parsed, task_class, terms)
            if score <= 0:
                continue
            parsed["score"] = round(score, 4)
            records.append(parsed)

    records.sort(key=lambda item: (item.get("score", 0.0), item.get("logged", "")), reverse=True)

    result = []
    used_chars = 0
    for record in records:
        compact = compact_entry(record)
        encoded = json.dumps(compact, separators=(",", ":"))
        if len(result) >= max_results:
            break
        if used_chars + len(encoded) > max_chars:
            break
        result.append(compact)
        used_chars += len(encoded)

    report = {
        "learning_loaded": len(result),
        "chars": used_chars,
        "results": result,
    }
    print(json.dumps(report, separators=(",", ":")))
    print(f"learning:metrics loaded={len(result)} chars={used_chars}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
