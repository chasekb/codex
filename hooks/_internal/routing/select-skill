#!/usr/bin/env bash
set -euo pipefail

task_class="${1:-general}"
confidence="${2:-1.0}"
keywords="${3:-}"
workspace_root="${4:-$(pwd)}"
script_dir="$(cd -- "$(dirname -- "$0")" && pwd)"

low_conf_threshold="0.70"
skill="tool-minimization"
fallback="false"

keywords_lc="$(printf '%s' "$keywords" | tr '[:upper:]' '[:lower:]')"

has_files() {
  local root="$1"
  shift
  [[ -d "$root" ]] || return 1
  for pattern in "$@"; do
    if compgen -G "$root/$pattern" >/dev/null; then
      return 0
    fi
  done
  return 1
}

has_ci_workflows="false"
has_compose_test_files="false"
has_package_markers="false"
if has_files "$workspace_root" ".github/workflows/*.yml" ".github/workflows/*.yaml"; then
  has_ci_workflows="true"
fi
if has_files "$workspace_root" "compose.test.yaml" "compose.test.yml" "docker-compose.test.yaml" "docker-compose.test.yml"; then
  has_compose_test_files="true"
fi
if has_files "$workspace_root" "package.json" "pyproject.toml" "Cargo.toml" "go.mod" "requirements.txt" "Pipfile" "poetry.lock"; then
  has_package_markers="true"
fi

if awk -v c="$confidence" -v t="$low_conf_threshold" 'BEGIN { exit !(c < t) }'; then
  skill="context-compaction"
  fallback="true"
else
  if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(self[-[:space:]]?improvement|log[[:space:]]+(this|that)?[[:space:]]*to[[:space:]]+learnings?|review[[:space:]]+learnings?|learning[[:space:]]+capture|extract[[:space:]]+skill|promote[[:space:]]+(this[[:space:]]+)?learning|pattern[[:space:]]+key|recurring[[:space:]]+pattern|knowledge[[:space:]]+gap|best[[:space:]]+practice|lesson[[:space:]]+learned)([[:space:]]|$)'; then
    skill="self-improvement"
  elif echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(skill[[:space:]]+maintenance|skill[[:space:]]+gap|skill[[:space:]]+gaps|skill[[:space:]]+candidate|skill[[:space:]]+candidates|skill[[:space:]]+authoring|skill[[:space:]]+discovery|external[[:space:]]+skill[[:space:]]+discovery|discover[[:space:]]+external[[:space:]]+skills|external[[:space:]]+skills|reusable[[:space:]]+skill|skill[[:space:]]+extraction|extract[[:space:]]+skill|install[[:space:]]+skill|update[[:space:]]+skill|author[[:space:]]+skill|create[[:space:]]+skill)([[:space:]]|$)'; then
    skill="self-improvement"
  elif echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(project insights|project health|backlog health|backlog metrics|backlog report|project report|aging items|stale items|wip pressure|wip limit|completion rate|completion rates)([[:space:]]|$)'; then
    skill="project-insights"
  elif echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(stale item review|stale items review|stale backlog|stale backlog items|stale recommendation|stale recommendations|stale task|stale tasks|defer stale|drop stale|keep stale)([[:space:]]|$)'; then
    skill="stale-item-review"
  elif echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(debug deep dive|deep debug|repeated failure|recurring failure|same failure|failing test|failing tests|tests failing|test failure|test failures|ci failure|ci failures|flaky test|flaky tests|regression failure|regression failures)([[:space:]]|$)'; then
    skill="systematic-debugging"
  elif echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(ci triage|failed ci|failed[[:space:]]+(github actions[[:space:]]+)?workflow|workflow failure|job log|build log|investigate ci|triage ci)([[:space:]]|$)'; then
    skill="ci-triage"
  elif [[ "$has_ci_workflows" == "true" ]] && echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(github actions build|workflow build|remote build|build workflow|ci build)([[:space:]]|$)'; then
    skill="github-actions-remote-build"
  elif echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(compose\\.test|docker-compose\\.test|compose-test|podman-compose|podman compose|compose test)([[:space:]]|$)'; then
    skill="podman-compose-test-runner"
  elif echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(release|publish|changelog|version bump|ship it)([[:space:]]|$)'; then
    skill="release-publish"
  elif echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(dependency|dependencies|outdated|audit|upgrade|update package|update dependency)([[:space:]]|$)'; then
    skill="dependency-maintenance"
  else
    case "$task_class" in
      request|change|general) skill="plan-verify-execute" ;;
      implement) skill="plan-verify-execute" ;;
      debug) skill="plan-verify-execute" ;;
      retro|retrospective) skill="global-workflow" ;;
      verify) skill="eval-driven-improvement" ;;
      plan|docs|research) skill="tool-minimization" ;;
      *) skill="tool-minimization" ;;
    esac

    if [[ "$skill" == "tool-minimization" || "$skill" == "plan-verify-execute" ]]; then
      catalog_skill="$("$script_dir/select-skill-catalog" "$task_class" "$confidence" "$keywords" "$workspace_root")"
      if [[ -n "$catalog_skill" ]]; then
        skill="$catalog_skill"
      fi
    fi
  fi

  if [[ "$skill" == "tool-minimization" || "$skill" == "plan-verify-execute" ]] && echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(eval|metric|regression|baseline)([[:space:]]|$)'; then
    skill="eval-driven-improvement"
  fi
fi

echo "skill:selected id=$skill fallback=$fallback"
echo "$skill"
