#!/usr/bin/env python3
import os
import re
import sys
from pathlib import Path


def tokenize(value):
    if not isinstance(value, str):
        return []
    return [part for part in re.split(r"[^a-z0-9]+", value.lower()) if len(part) > 2]


def parse_registry(path):
    entries = []
    if not path.is_file():
        return entries

    current = None
    in_skills = False
    with path.open("r", encoding="utf-8") as f:
        for raw in f:
            line = raw.rstrip("\n")
            stripped = line.strip()
            if stripped == "skills:":
                in_skills = True
                continue
            if not in_skills:
                continue
            if stripped.startswith("- id:"):
                if current:
                    entries.append(current)
                current = {
                    "id": stripped.split(":", 1)[1].strip(),
                    "file": "",
                    "tags": [],
                    "priority": 99,
                    "registry": str(path),
                }
                continue
            if current is None:
                continue
            if stripped.startswith("file:"):
                current["file"] = stripped.split(":", 1)[1].strip()
            elif stripped.startswith("priority:"):
                try:
                    current["priority"] = int(float(stripped.split(":", 1)[1].strip()))
                except Exception:
                    pass
            elif stripped.startswith("tags:"):
                value = stripped.split(":", 1)[1].strip()
                if value.startswith("[") and value.endswith("]"):
                    current["tags"] = [part.strip().strip("'\"") for part in value[1:-1].split(",") if part.strip()]
        if current:
            entries.append(current)
    return entries


def score_entry(entry, task_class, terms):
    skill_id = entry.get("id", "")
    if skill_id in {"tool-minimization", "context-compaction"}:
        return None

    haystack = " ".join(
        [
            skill_id,
            entry.get("file", ""),
            " ".join(entry.get("tags", []) or []),
        ]
    ).lower()
    tokens = set(tokenize(haystack))
    score = 0.0

    def token_matches(term, token):
        return token == term or token.startswith(term) or term.startswith(token)

    if task_class and any(token_matches(task_class.lower(), token) for token in tokens):
        score += 3.0
    if terms:
        score += sum(1.0 for term in terms if any(token_matches(term, token) for token in tokens))

    if score <= 0:
        return None

    priority = entry.get("priority", 99)
    try:
        score += max(0.0, 1.0 - (float(priority) * 0.05))
    except Exception:
        pass

    if "self-improvement" in tokens and any(term in {"learn", "learning", "skill", "improve"} for term in terms):
        score += 1.0

    return score


def main():
    task_class = sys.argv[1] if len(sys.argv) > 1 else "general"
    keywords = sys.argv[3] if len(sys.argv) > 3 else ""
    workspace_root = Path(sys.argv[4]) if len(sys.argv) > 4 else Path.cwd()
    scope = sys.argv[5] if len(sys.argv) > 5 else "external"

    terms = [term for term in tokenize(f"{task_class} {keywords}") if term]
    code_home = Path(os.environ.get("CODEX_HOME", str(Path.home() / ".codex")))
    registry_candidates = []
    env_registry = os.environ.get("CODEX_SKILLS_REGISTRY")
    if env_registry:
        registry_candidates.append(Path(env_registry))
    core_registry = workspace_root / "skills" / "registry.yaml"
    if core_registry.is_file():
        registry_candidates.append(core_registry)
    overlay_registry = workspace_root / "superpowers" / "skills" / "registry.yaml"
    if overlay_registry.is_file():
        registry_candidates.append(overlay_registry)
    registry_candidates.extend(
        [
            Path(os.environ.get("CODEX_EXTERNAL_SKILLS_REGISTRY", str(code_home / "external-skills" / "registry.yaml"))),
            Path.home() / ".agents" / "skills" / "registry.yaml",
        ]
    )

    best = None
    best_score = -1.0
    best_index = 10**6
    for index, registry_path in enumerate(registry_candidates):
        for entry in parse_registry(registry_path):
            score = score_entry(entry, task_class, terms)
            if score is None:
                continue
            if score > best_score or (score == best_score and index < best_index):
                best = entry.get("id", "")
                best_score = score
                best_index = index

    if best:
        print(best)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
