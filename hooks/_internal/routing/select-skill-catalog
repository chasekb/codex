#!/usr/bin/env python3
import os
import sys
from pathlib import Path

from skill_registry import parse_registry, registry_candidates as resolve_registry_candidates, tokenize


def score_entry(entry, task_class, terms):
    skill_id = entry.get("id", "")
    if skill_id in {"tool-minimization", "context-compaction"}:
        return None

    haystack = " ".join(
        [
            skill_id,
            entry.get("file", ""),
            " ".join(entry.get("tags", []) or []),
        ]
    ).lower()
    tokens = set(tokenize(haystack))
    score = 0.0

    def token_matches(term, token):
        return token == term or token.startswith(term) or term.startswith(token)

    if task_class and any(token_matches(task_class.lower(), token) for token in tokens):
        score += 3.0
    if terms:
        score += sum(1.0 for term in terms if any(token_matches(term, token) for token in tokens))

    if score <= 0:
        return None

    priority = entry.get("priority", 99)
    try:
        score += max(0.0, 1.0 - (float(priority) * 0.05))
    except Exception:
        pass

    if "self-improvement" in tokens and any(term in {"learn", "learning", "skill", "improve"} for term in terms):
        score += 1.0

    return score


def main():
    task_class = sys.argv[1] if len(sys.argv) > 1 else "general"
    keywords = sys.argv[3] if len(sys.argv) > 3 else ""
    workspace_root = Path(sys.argv[4]) if len(sys.argv) > 4 else Path.cwd()

    terms = [term for term in tokenize(f"{task_class} {keywords}") if term]
    code_home = Path(os.environ.get("CODEX_HOME", str(Path.home() / ".codex")))
    registry_paths = resolve_registry_candidates(root=workspace_root, code_home=code_home)

    best = None
    best_score = -1.0
    best_index = 10**6
    for index, registry_path in enumerate(registry_paths):
        for entry in parse_registry(registry_path):
            score = score_entry(entry, task_class, terms)
            if score is None:
                continue
            if score > best_score or (score == best_score and index < best_index):
                best = entry.get("id", "")
                best_score = score
                best_index = index

    if best:
        print(best)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
