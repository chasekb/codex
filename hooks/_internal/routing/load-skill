#!/usr/bin/env bash
set -euo pipefail

skill_id="${1:-}"
mode="${2:-metadata}"
max_chars="${3:-700}"
script_dir="$(cd -- "$(dirname -- "$0")" && pwd)"
export PYTHONPATH="$script_dir:${PYTHONPATH:-}"

find_repo_root() {
  local dir="$1"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/hooks.json" && -d "$dir/skills" && -d "$dir/rules" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname -- "$dir")"
  done
  return 1
}

root="$(find_repo_root "$script_dir")"
registry_file="${4:-${CODEX_SKILLS_REGISTRY:-$root/skills/registry.yaml}}"
code_home="${CODEX_HOME:-$HOME/.codex}"

[[ -n "$skill_id" ]] || { echo "skill:error missing_id"; exit 1; }
if [[ ! -f "$registry_file" ]]; then
  registry_file=""
fi

python_result="$(python3 - "$skill_id" "$root" "$code_home" "$registry_file" <<'PY'
import json
import sys
from pathlib import Path

from skill_registry import resolve_skill_entry

skill_id, root, code_home, preferred = sys.argv[1:5]
preferred_path = Path(preferred) if preferred else None
entry = resolve_skill_entry(skill_id, root=Path(root), code_home=Path(code_home), preferred=preferred_path)
if not entry:
    print(json.dumps({"error": "missing_file_for_id", "skill_id": skill_id}))
    raise SystemExit(1)
print(json.dumps(entry))
PY
)"
skill_resolved_rc=$?
if [[ $skill_resolved_rc -ne 0 ]]; then
  echo "skill:error missing_file_for_id=$skill_id"
  exit 1
fi

resolved_fields="$(python3 - "$python_result" <<'PY'
import json
import sys

data = json.loads(sys.argv[1])
print(data.get("file", ""))
print(data.get("registry", ""))
PY
)"
skill_file="$(printf '%s\n' "$resolved_fields" | sed -n '1p')"
registry_file="$(printf '%s\n' "$resolved_fields" | sed -n '2p')"

[[ -n "$skill_file" && -f "$skill_file" ]] || { echo "skill:error missing_file_for_id=$skill_id"; exit 1; }

extract_metadata() {
  awk '
    BEGIN { in_frontmatter=0; frontmatter_seen=0; in_instructions=0 }
    NR==1 && $0=="---" { in_frontmatter=1; frontmatter_seen=1; print; next }
    frontmatter_seen && in_frontmatter {
      print
      if ($0=="---") { in_frontmatter=0 }
      next
    }
    /^##[[:space:]]+Instructions$/ { in_instructions=1; exit }
    {
      if (!in_instructions) print
    }
  ' "$skill_file"
}

if [[ "$mode" == "metadata" ]]; then
  extract_metadata | awk -v m="$max_chars" '
    { out = out $0 "\n"; if (length(out) >= m) { print substr(out,1,m); exit } }
    END { if (length(out) < m) print out }
  '
else
  awk -v m="$max_chars" '{ out = out $0 "\n"; if (length(out) >= m) { print substr(out,1,m); exit } } END { if (length(out) < m) print out }' "$skill_file"
fi

loaded_chars="$(wc -c < "$skill_file" | tr -d ' ')"
if (( loaded_chars > max_chars )); then
  loaded_chars="$max_chars"
fi

echo "skill:metrics id=$skill_id loaded_chars=$loaded_chars"
