#!/usr/bin/env bash
set -euo pipefail

skill_id="${1:-}"
mode="${2:-metadata}"
max_chars="${3:-700}"
script_dir="$(cd -- "$(dirname -- "$0")" && pwd)"
find_repo_root() {
  local dir="$1"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/hooks.json" && -d "$dir/skills" && -d "$dir/rules" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname -- "$dir")"
  done
  return 1
}

root="$(find_repo_root "$script_dir")"
registry_file="${4:-${CODEX_SKILLS_REGISTRY:-$root/skills/registry.yaml}}"

[[ -n "$skill_id" ]] || { echo "skill:error missing_id"; exit 1; }
if [[ ! -f "$registry_file" ]]; then
  if [[ -f "${CODEX_EXTERNAL_SKILLS_REGISTRY:-${CODEX_HOME:-$HOME/.codex}/external-skills/registry.yaml}" ]]; then
    registry_file="${CODEX_EXTERNAL_SKILLS_REGISTRY:-${CODEX_HOME:-$HOME/.codex}/external-skills/registry.yaml}"
  elif [[ -f "$HOME/.agents/skills/registry.yaml" ]]; then
    registry_file="$HOME/.agents/skills/registry.yaml"
  else
    echo "skill:error missing_registry"
    exit 1
  fi
fi

skill_file="$(awk -v id="$skill_id" '
  $0 ~ "^  - id: "id"$" { found=1; next }
  found && $0 ~ "^    file: " { sub(/^    file: /, "", $0); print $0; exit }
' "$registry_file")"

registry_dir="$(cd -- "$(dirname -- "$registry_file")" && pwd)"
if [[ "$skill_file" != /* ]]; then
  skill_file="$registry_dir/$skill_file"
fi

if [[ ! -f "$skill_file" && "$registry_file" != "$HOME/.agents/skills/registry.yaml" && -f "$HOME/.agents/skills/registry.yaml" ]]; then
  registry_file="$HOME/.agents/skills/registry.yaml"
  skill_file="$(awk -v id="$skill_id" '
    $0 ~ "^  - id: "id"$" { found=1; next }
    found && $0 ~ "^    file: " { sub(/^    file: /, "", $0); print $0; exit }
  ' "$registry_file")"
  registry_dir="$(cd -- "$(dirname -- "$registry_file")" && pwd)"
  if [[ "$skill_file" != /* ]]; then
    skill_file="$registry_dir/$skill_file"
  fi
fi

if [[ ! -f "$skill_file" && "$registry_file" != "${CODEX_EXTERNAL_SKILLS_REGISTRY:-${CODEX_HOME:-$HOME/.codex}/external-skills/registry.yaml}" && -f "${CODEX_EXTERNAL_SKILLS_REGISTRY:-${CODEX_HOME:-$HOME/.codex}/external-skills/registry.yaml}" ]]; then
  registry_file="${CODEX_EXTERNAL_SKILLS_REGISTRY:-${CODEX_HOME:-$HOME/.codex}/external-skills/registry.yaml}"
  skill_file="$(awk -v id="$skill_id" '
    $0 ~ "^  - id: "id"$" { found=1; next }
    found && $0 ~ "^    file: " { sub(/^    file: /, "", $0); print $0; exit }
  ' "$registry_file")"
  registry_dir="$(cd -- "$(dirname -- "$registry_file")" && pwd)"
  if [[ "$skill_file" != /* ]]; then
    skill_file="$registry_dir/$skill_file"
  fi
fi

[[ -n "$skill_file" && -f "$skill_file" ]] || { echo "skill:error missing_file_for_id=$skill_id"; exit 1; }

extract_metadata() {
  awk '
    BEGIN { in_frontmatter=0; frontmatter_seen=0; in_instructions=0 }
    NR==1 && $0=="---" { in_frontmatter=1; frontmatter_seen=1; print; next }
    frontmatter_seen && in_frontmatter {
      print
      if ($0=="---") { in_frontmatter=0 }
      next
    }
    /^##[[:space:]]+Instructions$/ { in_instructions=1; exit }
    {
      if (!in_instructions) print
    }
  ' "$skill_file"
}

if [[ "$mode" == "metadata" ]]; then
  extract_metadata | awk -v m="$max_chars" '
    { out = out $0 "\n"; if (length(out) >= m) { print substr(out,1,m); exit } }
    END { if (length(out) < m) print out }
  '
else
  awk -v m="$max_chars" '{ out = out $0 "\n"; if (length(out) >= m) { print substr(out,1,m); exit } } END { if (length(out) < m) print out }' "$skill_file"
fi

loaded_chars="$(wc -c < "$skill_file" | tr -d ' ')"
if (( loaded_chars > max_chars )); then
  loaded_chars="$max_chars"
fi

echo "skill:metrics id=$skill_id loaded_chars=$loaded_chars"
