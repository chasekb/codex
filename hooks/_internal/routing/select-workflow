#!/usr/bin/env bash
set -euo pipefail

task_class="${1:-}"
confidence="${2:-1.0}"
keywords="${3:-}"
workspace_root="${4:-$(pwd)}"

low_confidence_threshold="0.70"

is_low_confidence() {
  awk -v c="$confidence" -v t="$low_confidence_threshold" 'BEGIN { exit !(c < t) }'
}

has_files() {
  local root="$1"
  shift
  [[ -d "$root" ]] || return 1
  for pattern in "$@"; do
    if compgen -G "$root/$pattern" >/dev/null; then
      return 0
    fi
  done
  return 1
}

keywords_lc="$(printf '%s' "$keywords" | tr '[:upper:]' '[:lower:]')"
has_ci_workflows="false"
has_compose_test_files="false"
has_package_markers="false"
if has_files "$workspace_root" ".github/workflows/*.yml" ".github/workflows/*.yaml"; then
  has_ci_workflows="true"
fi
if has_files "$workspace_root" "compose.test.yaml" "compose.test.yml" "docker-compose.test.yaml" "docker-compose.test.yml"; then
  has_compose_test_files="true"
fi
if has_files "$workspace_root" "package.json" "pyproject.toml" "Cargo.toml" "go.mod" "requirements.txt" "Pipfile" "poetry.lock"; then
  has_package_markers="true"
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(backlog|recommendation|recommendations|roadmap|prioritiz|project backlog|project management|task list|todo list|incomplete project)([[:space:]]|$)'; then
  echo "project-backlog-management"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(review closeout|closeout|request code review|code review|merge ready|finish branch|finish development branch|finalize branch|complete branch)([[:space:]]|$)'; then
  echo "review-closeout"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(multi-task|multitask|parallel|worktree|worktrees|subagent|dispatch agents|dispatching agents|independent tasks|split tasks|fan out)([[:space:]]|$)'; then
  echo "multi-task-implementation"
  exit 0
fi

if is_low_confidence; then
  echo "plan-only"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(self[-[:space:]]?improvement|log[[:space:]]+(this|that)?[[:space:]]*to[[:space:]]+learnings?|review[[:space:]]+learnings?|learning[[:space:]]+capture|extract[[:space:]]+skill|promote[[:space:]]+(this[[:space:]]+)?learning|pattern[[:space:]]+key|recurring[[:space:]]+pattern|knowledge[[:space:]]+gap|best[[:space:]]+practice|lesson[[:space:]]+learned)([[:space:]]|$)'; then
  echo "retro"
  exit 0
fi

if [[ "$has_ci_workflows" == "true" ]] && echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(ci triage|failed[[:space:]]+(github actions[[:space:]]+)?workflow|failed ci|workflow failure|build log|job log|triage ci|investigate ci)([[:space:]]|$)'; then
  echo "ci-triage"
  exit 0
fi

if [[ "$has_ci_workflows" == "true" ]] && echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(release|publish|changelog|version bump|ship it)([[:space:]]|$)'; then
  echo "release-publish"
  exit 0
fi

if [[ "$has_package_markers" == "true" ]] && echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(dependency|dependencies|outdated|audit|upgrade|update package|update dependency)([[:space:]]|$)'; then
  echo "dependency-maintenance"
  exit 0
fi

case "$task_class" in
  plan) echo "plan-only" ;;
  docs|research) echo "research" ;;
  ci|triage) echo "ci-triage" ;;
  release|publish) echo "release-publish" ;;
  deps|dependency|maintenance) echo "dependency-maintenance" ;;
  request|change|general) echo "request-standard" ;;
  implement) echo "implement-small" ;;
  debug) echo "debug-rca" ;;
  retro|retrospective) echo "retro" ;;
  verify|ui) echo "verify" ;;
  *) echo "unknown"; exit 2 ;;
esac
