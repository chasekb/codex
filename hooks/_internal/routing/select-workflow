#!/usr/bin/env bash
set -euo pipefail

task_class="${1:-}"
confidence="${2:-1.0}"
keywords="${3:-}"
workspace_root="${4:-$(pwd)}"

low_confidence_threshold="0.70"

is_low_confidence() {
  awk -v c="$confidence" -v t="$low_confidence_threshold" 'BEGIN { exit !(c < t) }'
}

has_files() {
  local root="$1"
  shift
  [[ -d "$root" ]] || return 1
  for pattern in "$@"; do
    if compgen -G "$root/$pattern" >/dev/null; then
      return 0
    fi
  done
  return 1
}

keywords_lc="$(printf '%s' "$keywords" | tr '[:upper:]' '[:lower:]')"
has_ci_workflows="false"
has_compose_test_files="false"
has_package_markers="false"
if has_files "$workspace_root" ".github/workflows/*.yml" ".github/workflows/*.yaml"; then
  has_ci_workflows="true"
fi
if has_files "$workspace_root" "compose.test.yaml" "compose.test.yml" "docker-compose.test.yaml" "docker-compose.test.yml"; then
  has_compose_test_files="true"
fi
if has_files "$workspace_root" "package.json" "pyproject.toml" "Cargo.toml" "go.mod" "requirements.txt" "Pipfile" "poetry.lock"; then
  has_package_markers="true"
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(weekly backlog review|weekly review|backlog weekly review|review backlog weekly)([[:space:]]|$)'; then
  echo "weekly-backlog-review"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(skill promotion|skill gap|skill gaps|skill candidate|skill candidates|skill authoring|skill extraction|extract skill|extract reusable skill|reusable skill|skill draft|promote skill|create skill|write skill|author skill)([[:space:]]|$)'; then
  echo "skill-promotion"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(skill maintenance|skill discovery|external skill discovery|discover external skills|discover external skill|external skills|discover install|install skill|install external skill|update skill|external skill)([[:space:]]|$)'; then
  echo "skill-maintenance"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(triage backlog|backlog triage|prioritize backlog|prioritise backlog|sort backlog|classify backlog|backlog review)([[:space:]]|$)'; then
  echo "backlog-triage"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(recommendation to task|promote recommendation|convert recommendation|task decomposition|decompose recommendation|break down recommendation)([[:space:]]|$)'; then
  echo "recommendation-to-task"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(review closeout|closeout|request code review|code review|merge ready|finish branch|finish development branch|finalize branch|complete branch)([[:space:]]|$)'; then
  echo "review-closeout"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(project insights|project health|backlog health|backlog metrics|backlog report|project report|aging items|stale items|wip pressure|wip limit|completion rate|completion rates)([[:space:]]|$)'; then
  echo "project-insights"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(stale item review|stale items review|stale backlog|stale backlog items|stale recommendation|stale recommendations|stale task|stale tasks|defer stale|drop stale|keep stale)([[:space:]]|$)'; then
  echo "stale-item-review"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(issue writing|write issue|issue writer|github issue|github issues|issue backlog|backlog issue|issue from backlog)([[:space:]]|$)'; then
  echo "issue-writing"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(debug deep dive|deep debug|repeated failure|recurring failure|same failure|failing test|failing tests|tests failing|test failure|test failures|ci failure|ci failures|flaky test|flaky tests|regression failure|regression failures)([[:space:]]|$)'; then
  echo "debug-deep-dive"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(implementation execution|execute implementation|implementation task|commit verify closeout|complete implementation)([[:space:]]|$)'; then
  echo "implementation-execution"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(backlog|recommendation|recommendations|roadmap|prioritiz|project backlog|project management|task list|todo list|incomplete project)([[:space:]]|$)'; then
  echo "project-backlog-management"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(multi-task|multitask|parallel|worktree|worktrees|subagent|dispatch agents|dispatching agents|independent tasks|split tasks|fan out)([[:space:]]|$)'; then
  echo "multi-task-implementation"
  exit 0
fi

if is_low_confidence; then
  echo "plan-only"
  exit 0
fi

if echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(self[-[:space:]]?improvement|log[[:space:]]+(this|that)?[[:space:]]*to[[:space:]]+learnings?|review[[:space:]]+learnings?|learning[[:space:]]+capture|extract[[:space:]]+skill|promote[[:space:]]+(this[[:space:]]+)?learning|pattern[[:space:]]+key|recurring[[:space:]]+pattern|knowledge[[:space:]]+gap|best[[:space:]]+practice|lesson[[:space:]]+learned)([[:space:]]|$)'; then
  echo "retro"
  exit 0
fi

if [[ "$has_ci_workflows" == "true" ]] && echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(ci triage|failed[[:space:]]+(github actions[[:space:]]+)?workflow|failed ci|workflow failure|build log|job log|triage ci|investigate ci)([[:space:]]|$)'; then
  echo "ci-triage"
  exit 0
fi

if [[ "$has_ci_workflows" == "true" ]] && echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(release|publish|changelog|version bump|ship it)([[:space:]]|$)'; then
  echo "release-publish"
  exit 0
fi

if [[ "$has_package_markers" == "true" ]] && echo "$keywords_lc" | grep -Eiq '(^|[[:space:]])(dependency|dependencies|outdated|audit|upgrade|update package|update dependency)([[:space:]]|$)'; then
  echo "dependency-maintenance"
  exit 0
fi

case "$task_class" in
  plan) echo "plan-only" ;;
  docs|research) echo "research" ;;
  ci|triage) echo "ci-triage" ;;
  release|publish) echo "release-publish" ;;
  deps|dependency|maintenance) echo "dependency-maintenance" ;;
  request|change|general) echo "request-standard" ;;
  implement) echo "implement-small" ;;
  debug) echo "debug-rca" ;;
  retro|retrospective) echo "retro" ;;
  verify|ui) echo "verify" ;;
  *) echo "unknown"; exit 2 ;;
esac
