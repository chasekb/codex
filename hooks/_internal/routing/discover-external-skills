#!/usr/bin/env python3
import json
import os
import re
import subprocess
import sys
from pathlib import Path


def tokenize(value):
    if not isinstance(value, str):
        return []
    return [part for part in re.split(r"[^a-z0-9]+", value.lower()) if len(part) > 2]


def first_text(*values):
    for value in values:
        if isinstance(value, str) and value.strip():
            return value.strip()
    return ""


def render_template(template, mapping):
    rendered = template
    for key, value in mapping.items():
        rendered = rendered.replace("{" + key + "}", value)
    return rendered


def run_command(command, cwd=None):
    proc = subprocess.run(
        ["/bin/bash", "-lc", command],
        cwd=cwd,
        capture_output=True,
        text=True,
        check=False,
    )
    return proc.returncode, (proc.stdout or "") + (proc.stderr or "")


def load_fixture_candidates():
    fixture = os.environ.get("CODEX_EXTERNAL_SKILL_DISCOVERY_JSON", "").strip()
    if not fixture:
        return []
    try:
        parsed = json.loads(fixture)
        if isinstance(parsed, dict):
            for key in ("candidates", "skills", "results", "items"):
                value = parsed.get(key)
                if isinstance(value, list):
                    return [item for item in value if isinstance(item, dict)]
            return []
        if isinstance(parsed, list):
            return [item for item in parsed if isinstance(item, dict)]
    except Exception:
        return []
    return []


def github_candidates():
    script_dir = Path(__file__).resolve().parent
    repo_root = script_dir.parent.parent.parent
    installer = repo_root / "skills" / ".system" / "skill-installer" / "scripts" / "list-skills.py"
    if not installer.is_file():
        return []
    proc = subprocess.run(
        [sys.executable, str(installer), "--repo", "openai/skills", "--path", "skills/.curated", "--format", "json"],
        capture_output=True,
        text=True,
        check=False,
        cwd=str(repo_root),
    )
    if proc.returncode != 0:
        return []
    try:
        parsed = json.loads(proc.stdout.strip() or "[]")
    except Exception:
        return []
    results = []
    for item in parsed:
        if not isinstance(item, dict):
            continue
        name = first_text(item.get("name"))
        if not name:
            continue
        results.append(
            {
                "source": "github",
                "name": name,
                "repo": "openai/skills",
                "path": f"skills/.curated/{name}",
                "ref": "main",
                "installed": bool(item.get("installed", False)),
            }
        )
    return results


def clawhub_candidates():
    search_cmd = os.environ.get("CODEX_CLAWHUB_SEARCH_CMD", "").strip()
    if not search_cmd:
        return []
    rc, out = run_command(search_cmd)
    if rc != 0:
        return []
    try:
        parsed = json.loads(out.strip() or "[]")
    except Exception:
        return []
    if isinstance(parsed, dict):
        for key in ("skills", "results", "items", "candidates"):
            value = parsed.get(key)
            if isinstance(value, list):
                parsed = value
                break
    if not isinstance(parsed, list):
        return []
    results = []
    for item in parsed:
        if not isinstance(item, dict):
            continue
        name = first_text(item.get("name"), item.get("id"))
        if not name:
            continue
        results.append(
            {
                "source": "clawhub",
                "name": name,
                "repo": first_text(item.get("repo"), item.get("repository")),
                "path": first_text(item.get("path")),
                "ref": first_text(item.get("ref"), item.get("branch"), "main"),
                "description": first_text(item.get("description"), item.get("summary")),
                "installed": bool(item.get("installed", False)),
            }
        )
    return results


def score_candidate(candidate, terms):
    tokens = set(tokenize(" ".join(
        [
            candidate.get("name", ""),
            candidate.get("path", ""),
            candidate.get("description", ""),
            candidate.get("source", ""),
        ]
    )))
    score = 0.0
    for term in terms:
        if term in tokens:
            score += 1.0
    if candidate.get("source") == "github":
        score += 0.25
    if candidate.get("installed"):
        score -= 0.5
    return score


def install_candidate(candidate, code_home):
    install_template = os.environ.get("CODEX_EXTERNAL_SKILL_INSTALL_CMD", "").strip()
    dest_root = Path(os.environ.get("CODEX_EXTERNAL_SKILL_DEST", str(code_home / "external-skills")))
    dest_dir = dest_root / candidate["name"]
    if dest_dir.is_dir():
        return 0, f"external_skill:already_installed name={candidate['name']}"

    dest_root.mkdir(parents=True, exist_ok=True)
    if install_template:
        mapping = {
            "name": candidate["name"],
            "repo": candidate.get("repo", ""),
            "path": candidate.get("path", ""),
            "ref": candidate.get("ref", "main"),
            "dest_root": str(dest_root),
            "dest_dir": str(dest_dir),
            "source_dir": candidate.get("source_dir", ""),
        }
        command = render_template(install_template, mapping)
        return run_command(command)

    if candidate.get("source") == "github":
        script_dir = Path(__file__).resolve().parent
        repo_root = script_dir.parent.parent.parent
        installer = repo_root / "skills" / ".system" / "skill-installer" / "scripts" / "install-skill-from-github.py"
        if not installer.is_file():
            return 1, "external_skill:error missing_installer"
        proc = subprocess.run(
            [
                sys.executable,
                str(installer),
                "--repo",
                candidate.get("repo", ""),
                "--path",
                candidate.get("path", ""),
                "--ref",
                candidate.get("ref", "main"),
                "--dest",
                str(dest_root),
            ],
            capture_output=True,
            text=True,
            check=False,
            cwd=str(repo_root),
        )
        return proc.returncode, (proc.stdout or "") + (proc.stderr or "")

    if candidate.get("source") == "clawhub":
        install_cmd = os.environ.get("CODEX_CLAWHUB_INSTALL_CMD", "").strip()
        if not install_cmd:
            return 1, "external_skill:error missing_clawhub_install_cmd"
        mapping = {
            "name": candidate["name"],
            "repo": candidate.get("repo", ""),
            "path": candidate.get("path", ""),
            "ref": candidate.get("ref", "main"),
            "dest_root": str(dest_root),
            "dest_dir": str(dest_dir),
            "source_dir": candidate.get("source_dir", ""),
        }
        command = render_template(install_cmd, mapping)
        return run_command(command)

    return 1, f"external_skill:error unsupported_source={candidate.get('source', '')}"


def main():
    task_class = first_text(sys.argv[1] if len(sys.argv) > 1 else "general")
    confidence = first_text(sys.argv[2] if len(sys.argv) > 2 else "1.0")
    keywords = first_text(sys.argv[3] if len(sys.argv) > 3 else "")
    current_skill = first_text(sys.argv[4] if len(sys.argv) > 4 else "")
    root = Path(first_text(sys.argv[5] if len(sys.argv) > 5 else str(Path.cwd())))

    mode = os.environ.get("CODEX_EXTERNAL_SKILL_DISCOVERY", "").strip().lower()
    if mode not in {"1", "true", "yes", "on", "discover", "install", "auto"}:
        report = {
            "status": "disabled",
            "task_class": task_class,
            "confidence": confidence,
            "keywords": keywords,
            "current_skill": current_skill,
            "candidates": [],
            "selected": {},
            "attempted_install": False,
            "installed": False,
            "install_rc": -1,
        }
        print(json.dumps(report, separators=(",", ":")))
        print(f"external_skill:disabled current={current_skill or 'none'}")
        return 0

    code_home = Path(os.environ.get("CODEX_HOME", str(Path.home() / ".codex")))
    dest_root = Path(os.environ.get("CODEX_EXTERNAL_SKILL_DEST", str(code_home / "external-skills")))
    terms = [term for term in tokenize(f"{task_class} {keywords}") if term]
    candidates = load_fixture_candidates()
    if not candidates:
        candidates.extend(github_candidates())
    if os.environ.get("CODEX_CLAWHUB_SEARCH_CMD", "").strip():
        candidates.extend(clawhub_candidates())

    ranked = []
    for candidate in candidates:
        if not isinstance(candidate, dict):
            continue
        candidate = dict(candidate)
        candidate["name"] = first_text(candidate.get("name"), candidate.get("id"))
        if not candidate["name"]:
            continue
        candidate.setdefault("source", "github")
        candidate.setdefault("ref", "main")
        candidate["score"] = round(score_candidate(candidate, terms), 4)
        ranked.append(candidate)
    ranked.sort(key=lambda item: (item.get("score", 0.0), item.get("installed", False)), reverse=True)
    selected = ranked[0] if ranked else {}

    installed = False
    install_rc = -1
    install_output = ""
    auto_install = mode in {"install", "auto"} or os.environ.get("CODEX_EXTERNAL_SKILL_AUTO_INSTALL", "").strip().lower() in {"1", "true", "yes", "on"}
    attempted_install = bool(selected and auto_install and selected.get("score", 0.0) > 0)
    if attempted_install:
        install_rc, install_output = install_candidate(selected, code_home)
        installed = install_rc == 0
        if installed:
            sync_script = root / "hooks" / "_internal" / "routing" / "sync-installed-skills-registry"
            if sync_script.is_file():
                sync_proc = subprocess.run(
                    [sys.executable, str(sync_script), str(dest_root), str(dest_root / "registry.yaml")],
                    capture_output=True,
                    text=True,
                    check=False,
                    cwd=str(root),
                )
                install_output = (install_output + "\n" + (sync_proc.stdout or "") + (sync_proc.stderr or "")).strip()
                installed = installed and sync_proc.returncode == 0

    report = {
        "status": "ok" if selected else "noop",
        "task_class": task_class,
        "confidence": confidence,
        "keywords": keywords,
        "current_skill": current_skill,
        "candidate_count": len(ranked),
        "selected": {k: v for k, v in selected.items() if k in {"source", "name", "repo", "path", "ref", "score", "installed"}},
        "attempted_install": attempted_install,
        "installed": installed,
        "install_rc": install_rc,
        "install_output": install_output[:2000],
        "candidates": [
            {k: v for k, v in candidate.items() if k in {"source", "name", "repo", "path", "ref", "description", "score", "installed"}}
            for candidate in ranked[:8]
        ],
    }

    os.makedirs(root / "outputs", exist_ok=True)
    json_path = root / "outputs" / "external-skill-discovery.json"
    md_path = root / "outputs" / "external-skill-discovery.md"
    json_path.write_text(json.dumps(report, separators=(",", ":")), encoding="utf-8")

    md_lines = [
        "# External Skill Discovery",
        "",
        f"Task class: {task_class}",
        f"Confidence: {confidence}",
        f"Current skill: {current_skill or 'none'}",
        f"Candidate count: {len(ranked)}",
        f"Selected: {selected.get('name', 'none') if selected else 'none'}",
        f"Installed: {str(installed).lower()}",
        "",
        "## Candidates",
    ]
    for candidate in ranked[:8]:
        md_lines.append(
            f"- `{candidate.get('name', '')}` source={candidate.get('source', '')} "
            f"score={candidate.get('score', 0)} installed={str(candidate.get('installed', False)).lower()}"
        )
    md_lines.extend(["", "## Result", f"- status: {report['status']}", f"- install_rc: {install_rc}"])
    md_path.write_text("\n".join(md_lines) + "\n", encoding="utf-8")

    print(json.dumps(report, separators=(",", ":")))
    print(f"external_skill:ok selected={selected.get('name', 'none') if selected else 'none'} installed={int(installed)} file={json_path}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
