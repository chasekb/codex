#!/usr/bin/env bash
set -euo pipefail

task_class="${1:-unknown}"
workflow="${2:-unknown}"
confidence="${3:-0}"
input_tokens="${4:-0}"
output_tokens="${5:-0}"
retries="${6:-0}"
fallbacks="${7:-0}"
tools="${8:-0}"
elapsed_ms="${9:-0}"
status="${10:-unknown}"
contract_valid="${11:-false}"
memory_loaded="${12:-0}"
memory_chars="${13:-0}"
memory_write_count="${14:-0}"
memory_dedup_count="${15:-0}"
memory_compact_kept="${16:-0}"
skill_id="${17:-none}"
skill_loaded_chars="${18:-0}"
skill_fallback="${19:-false}"

mkdir -p outputs
metrics_file="outputs/token-metrics.csv"

if [[ ! -f "$metrics_file" ]]; then
  printf 'timestamp,task_class,workflow,confidence,input_tokens,output_tokens,total_tokens,retries,fallbacks,tools,elapsed_ms,status,contract_valid,memory_loaded,memory_chars,memory_write_count,memory_dedup_count,memory_compact_kept,skill_id,skill_loaded_chars,skill_fallback\n' > "$metrics_file"
fi

total_tokens=$(( input_tokens + output_tokens ))
timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s\n' \
  "$timestamp" "$task_class" "$workflow" "$confidence" "$input_tokens" "$output_tokens" "$total_tokens" \
  "$retries" "$fallbacks" "$tools" "$elapsed_ms" "$status" "$contract_valid" \
  "$memory_loaded" "$memory_chars" "$memory_write_count" "$memory_dedup_count" "$memory_compact_kept" \
  "$skill_id" "$skill_loaded_chars" "$skill_fallback" >> "$metrics_file"

echo "metrics:ok file=$metrics_file"
