#!/usr/bin/env python3
import json
import os
import subprocess
import sys
from copy import deepcopy
from datetime import datetime, timedelta, timezone
from pathlib import Path


def now_iso():
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def today_stamp():
    return datetime.now(timezone.utc).strftime("%Y%m%d")


def repo_root():
    script_dir = Path(__file__).resolve().parent
    root = script_dir.parent.parent
    while root != root.parent:
        if (root / "hooks.json").is_file() and (root / "skills").is_dir() and (root / "rules").is_dir():
            return root
        root = root.parent
    return Path.cwd()


def backlog_path():
    return Path(os.environ.get("CODEX_BACKLOG_FILE", str(repo_root() / "MCP" / "backlog" / "backlog.json")))


def current_project_id():
    return normalize_text(
        os.environ.get("CODEX_BACKLOG_PROJECT")
        or os.environ.get("CODEX_PROJECT_ID")
        or os.environ.get("CODEX_PROJECT")
    )


def normalized_project_id(item):
    return normalize_text(item.get("project_id")) or normalize_text(item.get("scope")) or "global"


def is_visible_to_current_project(item):
    project_id = current_project_id()
    if not project_id:
        return True
    return normalized_project_id(item) in {project_id, "global"}


def backlog_scope_mode(explicit=None):
    scope = normalize_text(
        explicit
        or os.environ.get("CODEX_BACKLOG_SCOPE")
    ).lower()
    if scope in {"project", "global", "all"}:
        return scope
    return "project" if current_project_id() else "global"


def item_visible_in_scope(item, scope_mode):
    item_project = normalized_project_id(item)
    project_id = current_project_id()
    if scope_mode == "all":
        return True
    if scope_mode == "global":
        return item_project == "global"
    if scope_mode == "project":
        if project_id:
            return item_project == project_id
        return item_project == "global"
    return is_visible_to_current_project(item)


def default_state():
    return {
        "version": 1,
        "updated_at": "",
        "stats_scope": "global",
        "meta": {
            "last_weekly_review_at": "",
        },
        "recommendations": [],
        "implementation_tasks": [],
        "stats": {
            "open_recommendations": 0,
            "open_tasks": 0,
            "completed_tasks": 0,
        },
    }


def load_state():
    path = backlog_path()
    if not path.is_file():
        return default_state()
    try:
        with path.open("r", encoding="utf-8") as fh:
            data = json.load(fh)
        if isinstance(data, dict):
            state = default_state()
            state.update({k: v for k, v in data.items() if k in state})
            state.setdefault("meta", {})
            state.setdefault("recommendations", [])
            state.setdefault("implementation_tasks", [])
            state.setdefault("stats", {})
            state.setdefault("stats_scope", "global")
            return state
    except Exception:
        pass
    return default_state()


def scoped_stats(state, scope_mode):
    recommendations = [
        item for item in state["recommendations"]
        if item.get("status", "open") not in {"completed", "closed", "resolved", "deferred"}
        and item_visible_in_scope(item, scope_mode)
    ]
    tasks = [
        item for item in state["implementation_tasks"]
        if item.get("status", "pending") not in {"completed", "closed", "resolved", "cancelled"}
        and item_visible_in_scope(item, scope_mode)
    ]
    return {
        "open_recommendations": len(recommendations),
        "open_tasks": len(tasks),
        "completed_tasks": sum(
            1
            for item in state["implementation_tasks"]
            if item.get("status") == "completed" and item_visible_in_scope(item, scope_mode)
        ),
    }


def save_state(state, scope_mode=None):
    path = backlog_path()
    path.parent.mkdir(parents=True, exist_ok=True)
    scope_mode = backlog_scope_mode(scope_mode)
    state["updated_at"] = now_iso()
    state["stats_scope"] = scope_mode
    state["stats"] = scoped_stats(state, scope_mode)
    with path.open("w", encoding="utf-8") as fh:
        json.dump(state, fh, indent=2, sort_keys=True)
        fh.write("\n")


def read_input_payload():
    raw = sys.stdin.read().strip()
    if not raw:
        return {}
    try:
        parsed = json.loads(raw)
        return parsed if isinstance(parsed, dict) else {}
    except Exception:
        return {}


def render_template(template, mapping):
    rendered = template
    for key, value in mapping.items():
        rendered = rendered.replace("{" + key + "}", value)
    return rendered


def run_command_with_input(command, stdin_text, cwd=None):
    proc = subprocess.run(
        ["/bin/bash", "-lc", command],
        input=stdin_text,
        cwd=cwd,
        capture_output=True,
        text=True,
        check=False,
    )
    return proc.returncode, (proc.stdout or "") + (proc.stderr or "")


def normalize_text(value):
    if isinstance(value, str):
        return value.strip()
    return ""


def normalize_tags(value):
    if not isinstance(value, list):
        return []
    tags = []
    for item in value:
        text = normalize_text(item)
        if text:
            tags.append(text.lower())
    return sorted(set(tags))


def item_matches(item, kind, title):
    return item.get("kind") == kind and normalize_text(item.get("title")).lower() == normalize_text(title).lower()


def recommendation_id(state):
    existing = [item.get("id", "") for item in state["recommendations"]]
    seq = 1
    stamp = today_stamp()
    while True:
        candidate = f"REC-{stamp}-{seq:03d}"
        if candidate not in existing:
            return candidate
        seq += 1


def task_id(state):
    existing = [item.get("id", "") for item in state["implementation_tasks"]]
    seq = 1
    stamp = today_stamp()
    while True:
        candidate = f"TASK-{stamp}-{seq:03d}"
        if candidate not in existing:
            return candidate
        seq += 1


def parse_iso_datetime(value):
    text_value = normalize_text(value)
    if not text_value:
        return None
    try:
        if text_value.endswith("Z"):
            text_value = text_value[:-1] + "+00:00"
        return datetime.fromisoformat(text_value)
    except Exception:
        return None


def active_recommendations(state, scope_mode=None):
    scope_mode = backlog_scope_mode(scope_mode)
    return [
        item for item in state["recommendations"]
        if item.get("status", "open") not in {"completed", "closed", "resolved", "deferred"}
        and item_visible_in_scope(item, scope_mode)
    ]


def active_tasks(state, scope_mode=None):
    scope_mode = backlog_scope_mode(scope_mode)
    return [
        item for item in state["implementation_tasks"]
        if item.get("status", "pending") not in {"completed", "closed", "resolved", "cancelled"}
        and item_visible_in_scope(item, scope_mode)
    ]


def sort_key(item):
    priority_rank = {"high": 0, "medium": 1, "low": 2}
    created = normalize_text(item.get("created_at"))
    return (priority_rank.get(normalize_text(item.get("priority")).lower(), 3), created)


def render_backlog_report(state, stale_after_days=7, wip_limit=3, scope_mode=None):
    scope_mode = backlog_scope_mode(scope_mode)
    recommendations = active_recommendations(state, scope_mode)
    tasks = active_tasks(state, scope_mode)
    recommendations.sort(key=sort_key)
    tasks.sort(key=sort_key)
    stale_cutoff = datetime.now(timezone.utc) - timedelta(days=max(1, int(stale_after_days)))
    stale_recommendations = []
    stale_tasks = []
    for item in recommendations:
        created_at = parse_iso_datetime(item.get("created_at"))
        if created_at and created_at <= stale_cutoff:
            stale_recommendations.append(item)
    for item in tasks:
        created_at = parse_iso_datetime(item.get("created_at"))
        if created_at and created_at <= stale_cutoff:
            stale_tasks.append(item)
    over_wip_limit = max(0, len(tasks) - max(1, int(wip_limit)))
    return {
        "status": "ok",
        "backlog_file": str(backlog_path()),
        "scope": scope_mode,
        "project_id": current_project_id(),
        "meta": deepcopy(state.get("meta", {})),
        "stats": scoped_stats(state, scope_mode),
        "recommendations": recommendations[:20],
        "implementation_tasks": tasks[:20],
        "stale_recommendations": stale_recommendations[:20],
        "stale_tasks": stale_tasks[:20],
        "stale_count": len(stale_recommendations),
        "stale_task_count": len(stale_tasks),
        "stale_total_count": len(stale_recommendations) + len(stale_tasks),
        "wip_limit": max(1, int(wip_limit)),
        "wip_over_limit": over_wip_limit,
    }


def intake(state, payload):
    kind = normalize_text(payload.get("kind", "recommendation")).lower() or "recommendation"
    title = normalize_text(payload.get("title"))
    if not title:
        return 1, {"error": "missing_title"}
    summary = normalize_text(payload.get("summary"))
    details = normalize_text(payload.get("details"))
    source = normalize_text(payload.get("source")) or "conversation"
    priority = normalize_text(payload.get("priority")) or "medium"
    tags = normalize_tags(payload.get("tags", []))
    related = normalize_text(payload.get("related_id")) or normalize_text(payload.get("parent_id"))
    project_id = normalize_text(payload.get("project_id")) or current_project_id() or "global"

    if kind not in {"recommendation", "task"}:
        return 1, {"error": f"unsupported_kind={kind}"}

    target_list = state["recommendations"] if kind == "recommendation" else state["implementation_tasks"]
    for item in target_list:
        if (
            item_matches(item, kind, title)
            and normalized_project_id(item) == project_id
            and item.get("status") not in {"completed", "closed", "resolved"}
        ):
            return 0, {"status": "duplicate", "id": item.get("id"), "kind": kind}

    ident = recommendation_id(state) if kind == "recommendation" else task_id(state)
    item = {
        "id": ident,
        "kind": kind,
        "project_id": project_id,
        "title": title,
        "summary": summary or title,
        "details": details,
        "source": source,
        "priority": priority,
        "status": "open" if kind == "recommendation" else "pending",
        "tags": tags,
        "created_at": now_iso(),
        "updated_at": now_iso(),
    }
    if related:
        item["related_id"] = related
    if kind == "task":
        item["commit_sha"] = normalize_text(payload.get("commit_sha"))
        item["verified"] = bool(payload.get("verified", False))
    target_list.append(item)
    return 0, {"status": "intaked", "id": ident, "kind": kind}


def promote(state, recommendation_id_value, payload):
    rec = next((item for item in state["recommendations"] if item.get("id") == recommendation_id_value), None)
    if not rec:
        return 1, {"error": f"missing_recommendation={recommendation_id_value}"}
    if not is_visible_to_current_project(rec):
        return 1, {"error": f"wrong_project={normalized_project_id(rec)}"}
    if rec.get("status") in {"completed", "closed", "resolved"}:
        return 0, {"status": "noop", "reason": "already_closed", "id": recommendation_id_value}

    title = normalize_text(payload.get("title")) or rec.get("title", "")
    project_id = normalize_text(payload.get("project_id")) or normalized_project_id(rec)
    task = {
        "id": task_id(state),
        "kind": "task",
        "project_id": project_id,
        "title": title,
        "summary": normalize_text(payload.get("summary")) or rec.get("summary", title),
        "details": normalize_text(payload.get("details")) or rec.get("details", ""),
        "source": normalize_text(payload.get("source")) or rec.get("source", "recommendation"),
        "priority": normalize_text(payload.get("priority")) or rec.get("priority", "medium"),
        "status": "pending",
        "tags": normalize_tags(payload.get("tags", rec.get("tags", []))),
        "created_at": now_iso(),
        "updated_at": now_iso(),
        "related_id": recommendation_id_value,
        "recommendation_id": recommendation_id_value,
    }
    task_commit = normalize_text(payload.get("commit_sha"))
    if task_commit:
        task["commit_sha"] = task_commit
    task_verified = payload.get("verified")
    if task_verified is not None:
        task["verified"] = bool(task_verified)
    state["implementation_tasks"].append(task)
    rec["status"] = "promoted"
    rec["updated_at"] = now_iso()
    rec.setdefault("implementation_tasks", []).append(task["id"])
    return 0, {"status": "promoted", "recommendation_id": recommendation_id_value, "task_id": task["id"]}


def recommendation_tasks_completed(state, recommendation):
    task_ids = recommendation.get("implementation_tasks", [])
    if not task_ids:
        return False
    for task_id_value in task_ids:
        task = next((item for item in state["implementation_tasks"] if item.get("id") == task_id_value), None)
        if not task or task.get("status") != "completed":
            return False
    return True


def complete(state, task_id_value, payload):
    task = next((item for item in state["implementation_tasks"] if item.get("id") == task_id_value), None)
    commit_sha = normalize_text(payload.get("commit_sha"))
    if task:
        if not is_visible_to_current_project(task):
            return 1, {"error": f"wrong_project={normalized_project_id(task)}"}
        task["status"] = "completed"
        task["updated_at"] = now_iso()
        if commit_sha:
            task["commit_sha"] = commit_sha
        if payload.get("verified") is not None:
            task["verified"] = bool(payload.get("verified"))
        task["completed_at"] = now_iso()

        rec_id = normalize_text(task.get("recommendation_id")) or normalize_text(task.get("related_id"))
        if rec_id:
            rec = next((item for item in state["recommendations"] if item.get("id") == rec_id), None)
            if rec:
                rec["updated_at"] = now_iso()
                if recommendation_tasks_completed(state, rec):
                    rec["status"] = "completed"
                    rec["closed_at"] = now_iso()
        return 0, {"status": "completed", "task_id": task_id_value, "commit_sha": commit_sha}

    rec = next((item for item in state["recommendations"] if item.get("id") == task_id_value), None)
    if not rec:
        return 1, {"error": f"missing_task_or_recommendation={task_id_value}"}
    if not is_visible_to_current_project(rec):
        return 1, {"error": f"wrong_project={normalized_project_id(rec)}"}
    rec["status"] = "completed"
    rec["updated_at"] = now_iso()
    rec["closed_at"] = now_iso()
    if commit_sha:
        rec["commit_sha"] = commit_sha
    if payload.get("verified") is not None:
        rec["verified"] = bool(payload.get("verified"))
    return 0, {"status": "completed", "recommendation_id": task_id_value, "commit_sha": commit_sha}


def review(state, payload):
    stale_after_days = int(payload.get("stale_after_days", 7) or 7)
    wip_limit = int(payload.get("wip_limit", 3) or 3)
    force = bool(payload.get("force", False))
    scope_mode = backlog_scope_mode(payload.get("scope"))
    last_review = normalize_text(state.get("meta", {}).get("last_weekly_review_at"))
    last_review_dt = parse_iso_datetime(last_review)
    due = force or not last_review_dt or (datetime.now(timezone.utc) - last_review_dt >= timedelta(days=max(1, stale_after_days)))
    report = render_backlog_report(state, stale_after_days=stale_after_days, wip_limit=wip_limit, scope_mode=scope_mode)
    report["review_due"] = due
    report["last_weekly_review_at"] = last_review

    if due:
        state.setdefault("meta", {})["last_weekly_review_at"] = now_iso()
        report["last_weekly_review_at"] = state["meta"]["last_weekly_review_at"]
        report["reviewed_at"] = report["last_weekly_review_at"]
        save_state(state)
        report["stats"] = deepcopy(state.get("stats", {}))
    return 0, report


def mirror(state, action, payload, result):
    sync_template = os.environ.get("CODEX_CLAWHUB_BACKLOG_SYNC_CMD", "").strip()
    if not sync_template:
        return 0, {"status": "skipped", "reason": "missing_clawhub_sync_cmd"}
    dest_root = Path(os.environ.get("CODEX_CLAWHUB_BACKLOG_DEST", str(repo_root() / "outputs" / "clawhub-backlog")))
    dest_root.mkdir(parents=True, exist_ok=True)
    mapping = {
        "backlog_file": str(backlog_path()),
        "dest_root": str(dest_root),
        "open_recommendations": str(state.get("stats", {}).get("open_recommendations", 0)),
        "open_tasks": str(state.get("stats", {}).get("open_tasks", 0)),
        "completed_tasks": str(state.get("stats", {}).get("completed_tasks", 0)),
        "action": action,
        "payload_json": json.dumps(payload or {}, sort_keys=True),
        "result_json": json.dumps(result or {}, sort_keys=True),
    }
    command = render_template(sync_template, mapping)
    stdin_text = json.dumps(
        {
            "backlog_file": str(backlog_path()),
            "state": state,
            "payload": payload or {},
            "result": result or {},
            "action": action,
        },
        indent=2,
        sort_keys=True,
    )
    rc, out = run_command_with_input(command, stdin_text)
    return rc, {"status": "ok" if rc == 0 else "failed", "output": out[:1000]}


def list_state(state, scope_mode=None):
    report = render_backlog_report(state, scope_mode=scope_mode)
    print(json.dumps(report, indent=2, sort_keys=True))
    print(
        "backlog:metrics "
        f"scope={report.get('scope', backlog_scope_mode(scope_mode))} "
        f"open_recommendations={report['stats'].get('open_recommendations', len(report['recommendations']))} "
        f"open_tasks={report['stats'].get('open_tasks', len(report['implementation_tasks']))} "
        f"completed_tasks={report['stats'].get('completed_tasks', 0)}"
    )
    return 0


def main():
    state = load_state()
    if len(sys.argv) < 2:
        return list_state(state)

    command = sys.argv[1].strip().lower()
    payload = read_input_payload()

    if command == "intake":
        rc, result = intake(state, payload)
    elif command == "promote":
        rec_id = normalize_text(sys.argv[2]) if len(sys.argv) > 2 else normalize_text(payload.get("recommendation_id"))
        rc, result = promote(state, rec_id, payload)
    elif command == "complete":
        task_id_value = normalize_text(sys.argv[2]) if len(sys.argv) > 2 else normalize_text(payload.get("task_id"))
        rc, result = complete(state, task_id_value, payload)
    elif command == "review":
        rc, result = review(state, payload)
    elif command in {"list", "status"}:
        return list_state(state, payload.get("scope"))
    else:
        print(f"backlog:error unsupported_command={command}")
        return 1

    if rc == 0 and command != "review":
        save_state(state)
        mirror_rc, mirror_result = mirror(state, command, payload, result)
        if mirror_rc == 0:
            print("backlog:mirror status=ok")
        elif mirror_result.get("output"):
            print(f"backlog:mirror status=failed details={normalize_text(mirror_result['output'])[:220]}")
    elif rc == 0 and command == "review" and result.get("review_due"):
        mirror_rc, mirror_result = mirror(state, command, payload, result)
        if mirror_rc == 0:
            print("backlog:mirror status=ok")
        elif mirror_result.get("output"):
            print(f"backlog:mirror status=failed details={normalize_text(mirror_result['output'])[:220]}")
    print(json.dumps(result, sort_keys=True))
    if command == "review":
        print(
            "backlog:review "
            f"loaded=1 "
            f"scope={result.get('scope', backlog_scope_mode(payload.get('scope')))} "
            f"review_due={int(bool(result.get('review_due', False)))} "
            f"open_recommendations={result.get('stats', {}).get('open_recommendations', state['stats'].get('open_recommendations', 0))} "
            f"open_tasks={result.get('stats', {}).get('open_tasks', state['stats'].get('open_tasks', 0))} "
            f"completed_tasks={result.get('stats', {}).get('completed_tasks', state['stats'].get('completed_tasks', 0))} "
            f"stale_count={int(result.get('stale_count', 0))} "
            f"wip_over_limit={int(result.get('wip_over_limit', 0))} "
            f"last_weekly_review_at={normalize_text(result.get('last_weekly_review_at', ''))}"
        )
    else:
        print(
            "backlog:metrics "
            f"open_recommendations={state['stats'].get('open_recommendations', 0)} "
            f"open_tasks={state['stats'].get('open_tasks', 0)} "
            f"completed_tasks={state['stats'].get('completed_tasks', 0)}"
        )
    return rc


if __name__ == "__main__":
    raise SystemExit(main())
