#!/usr/bin/env bash
set -euo pipefail

task_class="${1:-unknown}"
workflow="${2:-unknown}"
confidence="${3:-0}"
input_tokens="${4:-0}"
output_tokens="${5:-0}"
retries="${6:-0}"
fallbacks="${7:-0}"
tools="${8:-0}"
elapsed_ms="${9:-0}"
status="${10:-unknown}"
contract_valid="${11:-false}"
memory_loaded="${12:-0}"
memory_chars="${13:-0}"
learning_loaded="${14:-0}"
learning_chars="${15:-0}"
failure_history_loaded="${16:-0}"
failure_history_chars="${17:-0}"
playbook_loaded="${18:-0}"
playbook_chars="${19:-0}"
search_hints_loaded="${20:-0}"
search_hints_chars="${21:-0}"
memory_write_count="${22:-0}"
memory_dedup_count="${23:-0}"
memory_compact_kept="${24:-0}"
search_tool_count="${25:-0}"
search_query_count="${26:-0}"
search_source_count="${27:-0}"
search_reuse_hit="${28:-0}"
search_memory_write_count="${29:-0}"
hook_name="${30:-unknown}"
pipeline_stage="${31:-postrun}"
workflow_selected="${32:-unknown}"
skill_id="${33:-none}"
skill_loaded_chars="${34:-0}"
skill_fallback="${35:-false}"
budget_controller_estimate_scale="${36:-1.0}"
budget_controller_estimate_scale_pct="${37:-100.0}"
output_compact_runs="${38:-0}"
output_compact_removed="${39:-0}"
output_compact_compacted="${40:-0}"
output_compact_kept="${41:-0}"
pre_prompt_budget_soft="${42:-0}"
pre_prompt_budget_hard="${43:-0}"
pre_prompt_objective_chars="${44:-0}"
pre_prompt_context_chars="${45:-0}"
pre_prompt_estimate_scale="${46:-1.0}"
pre_prompt_estimate_scale_pct="${47:-100.0}"
pre_prompt_est_tokens="${48:-0}"
pre_prompt_estimate_error_tokens="${49:-0}"
pre_prompt_estimate_error_rate="${50:-0}"
pre_prompt_utilization="${51:-0}"
pre_prompt_margin_tokens="${52:-0}"
pre_prompt_adjustment_warranted="${53:-false}"
external_skill_discovery_runs="${54:-0}"
external_skill_install_attempts="${55:-0}"
external_skill_install_successes="${56:-0}"
external_skill_id="${57:-}"
external_skill_source="${58:-}"
workflow_registry_label="${59:-}"
workflow_source_file="${60:-}"
prompt_cache_static_context_chars="${61:-0}"
prompt_cache_dynamic_objective_chars="${62:-0}"
prompt_cache_total_chars="${63:-0}"
prompt_cache_static_ratio="${64:-0.0}"
prompt_cache_eligible="${65:-false}"

mkdir -p outputs
metrics_file="outputs/token-metrics.csv"
desired_header='timestamp,task_class,workflow,confidence,input_tokens,output_tokens,total_tokens,retries,fallbacks,tools,elapsed_ms,status,contract_valid,memory_loaded,memory_chars,learning_loaded,learning_chars,failure_history_loaded,failure_history_chars,playbook_loaded,playbook_chars,search_hints_loaded,search_hints_chars,memory_write_count,memory_dedup_count,memory_compact_kept,output_compact_runs,output_compact_removed,output_compact_compacted,output_compact_kept,search_tool_count,search_query_count,search_source_count,search_reuse_hit,search_memory_write_count,hook_name,pipeline_stage,workflow_selected,skill_id,skill_loaded_chars,skill_fallback,budget_controller_estimate_scale,budget_controller_estimate_scale_pct,pre_prompt_budget_soft,pre_prompt_budget_hard,pre_prompt_objective_chars,pre_prompt_context_chars,pre_prompt_estimate_scale,pre_prompt_estimate_scale_pct,pre_prompt_est_tokens,pre_prompt_estimate_error_tokens,pre_prompt_estimate_error_rate,pre_prompt_utilization,pre_prompt_margin_tokens,pre_prompt_adjustment_warranted,external_skill_discovery_runs,external_skill_install_attempts,external_skill_install_successes,external_skill_id,external_skill_source,workflow_registry_label,workflow_source_file,prompt_cache_static_context_chars,prompt_cache_dynamic_objective_chars,prompt_cache_total_chars,prompt_cache_static_ratio,prompt_cache_eligible'
legacy_header='timestamp,task_class,workflow,confidence,input_tokens,output_tokens,total_tokens,retries,fallbacks,tools,elapsed_ms,status,contract_valid,memory_loaded,memory_chars,memory_write_count,memory_dedup_count,memory_compact_kept,skill_id,skill_loaded_chars,skill_fallback'

if [[ ! -f "$metrics_file" ]]; then
  printf '%s\n' "$desired_header" > "$metrics_file"
elif [[ "$(head -n1 "$metrics_file")" != "$desired_header" ]]; then
  python3 - "$metrics_file" "$desired_header" "$legacy_header" <<'PY'
import csv
import sys
from pathlib import Path

metrics_file = Path(sys.argv[1])
desired_header = sys.argv[2].split(",")
legacy_header = sys.argv[3].split(",")

rows = []
with metrics_file.open("r", encoding="utf-8", newline="") as f:
    reader = csv.reader(f)
    existing_header = next(reader, [])
    for row in reader:
        if not row:
            continue
        source_header = existing_header or legacy_header
        data = {col: row[i] if i < len(row) else "" for i, col in enumerate(source_header)}
        rows.append([data.get(col, "") for col in desired_header])

with metrics_file.open("w", encoding="utf-8", newline="") as f:
    writer = csv.writer(f)
    writer.writerow(desired_header)
    writer.writerows(rows)
PY
fi

total_tokens=$(( input_tokens + output_tokens ))
timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

python3 - "$metrics_file" "$desired_header" \
  "$timestamp" "$task_class" "$workflow" "$confidence" "$input_tokens" "$output_tokens" "$total_tokens" \
  "$retries" "$fallbacks" "$tools" "$elapsed_ms" "$status" "$contract_valid" \
  "$memory_loaded" "$memory_chars" "$learning_loaded" "$learning_chars" "$failure_history_loaded" "$failure_history_chars" "$playbook_loaded" "$playbook_chars" "$search_hints_loaded" "$search_hints_chars" "$memory_write_count" "$memory_dedup_count" "$memory_compact_kept" \
  "$output_compact_runs" "$output_compact_removed" "$output_compact_compacted" "$output_compact_kept" \
  "$search_tool_count" "$search_query_count" "$search_source_count" "$search_reuse_hit" "$search_memory_write_count" \
  "$hook_name" "$pipeline_stage" "$workflow_selected" "$skill_id" "$skill_loaded_chars" "$skill_fallback" \
  "$budget_controller_estimate_scale" "$budget_controller_estimate_scale_pct" \
  "$pre_prompt_budget_soft" "$pre_prompt_budget_hard" "$pre_prompt_objective_chars" "$pre_prompt_context_chars" \
  "$pre_prompt_estimate_scale" "$pre_prompt_estimate_scale_pct" "$pre_prompt_est_tokens" "$pre_prompt_estimate_error_tokens" "$pre_prompt_estimate_error_rate" "$pre_prompt_utilization" "$pre_prompt_margin_tokens" "$pre_prompt_adjustment_warranted" \
  "$external_skill_discovery_runs" "$external_skill_install_attempts" "$external_skill_install_successes" \
  "$external_skill_id" "$external_skill_source" \
  "$workflow_registry_label" "$workflow_source_file" \
  "$prompt_cache_static_context_chars" "$prompt_cache_dynamic_objective_chars" "$prompt_cache_total_chars" "$prompt_cache_static_ratio" "$prompt_cache_eligible" <<'PY'
import csv
import sys
from pathlib import Path

metrics_file = Path(sys.argv[1])
desired_header = sys.argv[2].split(",")
row = sys.argv[3:]

if len(row) != len(desired_header):
    raise SystemExit(f"row_length_mismatch:{len(row)}!={len(desired_header)}")

with metrics_file.open("a", encoding="utf-8", newline="") as f:
    writer = csv.writer(f)
    writer.writerow(row)
PY

echo "metrics:ok file=$metrics_file"
