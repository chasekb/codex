#!/usr/bin/env bash
set -euo pipefail

task_class="${1:-unknown}"
workflow="${2:-unknown}"
confidence="${3:-0}"
input_tokens="${4:-0}"
output_tokens="${5:-0}"
retries="${6:-0}"
fallbacks="${7:-0}"
tools="${8:-0}"
elapsed_ms="${9:-0}"
status="${10:-unknown}"
contract_valid="${11:-false}"
memory_loaded="${12:-0}"
memory_chars="${13:-0}"
memory_write_count="${14:-0}"
memory_dedup_count="${15:-0}"
memory_compact_kept="${16:-0}"
search_tool_count="${17:-0}"
search_query_count="${18:-0}"
search_source_count="${19:-0}"
search_reuse_hit="${20:-0}"
search_memory_write_count="${21:-0}"
hook_name="${22:-unknown}"
pipeline_stage="${23:-postrun}"
workflow_selected="${24:-unknown}"
skill_id="${25:-none}"
skill_loaded_chars="${26:-0}"
skill_fallback="${27:-false}"
output_compact_runs="${28:-0}"
output_compact_removed="${29:-0}"
output_compact_compacted="${30:-0}"
output_compact_kept="${31:-0}"

mkdir -p outputs
metrics_file="outputs/token-metrics.csv"
desired_header='timestamp,task_class,workflow,confidence,input_tokens,output_tokens,total_tokens,retries,fallbacks,tools,elapsed_ms,status,contract_valid,memory_loaded,memory_chars,memory_write_count,memory_dedup_count,memory_compact_kept,output_compact_runs,output_compact_removed,output_compact_compacted,output_compact_kept,search_tool_count,search_query_count,search_source_count,search_reuse_hit,search_memory_write_count,hook_name,pipeline_stage,workflow_selected,skill_id,skill_loaded_chars,skill_fallback'
legacy_header='timestamp,task_class,workflow,confidence,input_tokens,output_tokens,total_tokens,retries,fallbacks,tools,elapsed_ms,status,contract_valid,memory_loaded,memory_chars,memory_write_count,memory_dedup_count,memory_compact_kept,skill_id,skill_loaded_chars,skill_fallback'

if [[ ! -f "$metrics_file" ]]; then
  printf '%s\n' "$desired_header" > "$metrics_file"
elif [[ "$(head -n1 "$metrics_file")" != "$desired_header" ]]; then
  python3 - "$metrics_file" "$desired_header" "$legacy_header" <<'PY'
import csv
import sys
from pathlib import Path

metrics_file = Path(sys.argv[1])
desired_header = sys.argv[2].split(",")
legacy_header = sys.argv[3].split(",")

rows = []
with metrics_file.open("r", encoding="utf-8", newline="") as f:
    reader = csv.reader(f)
    existing_header = next(reader, [])
    for row in reader:
        if not row:
            continue
        source_header = existing_header or legacy_header
        data = {col: row[i] if i < len(row) else "" for i, col in enumerate(source_header)}
        rows.append([data.get(col, "") for col in desired_header])

with metrics_file.open("w", encoding="utf-8", newline="") as f:
    writer = csv.writer(f)
    writer.writerow(desired_header)
    writer.writerows(rows)
PY
fi

total_tokens=$(( input_tokens + output_tokens ))
timestamp="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s\n' \
  "$timestamp" "$task_class" "$workflow" "$confidence" "$input_tokens" "$output_tokens" "$total_tokens" \
  "$retries" "$fallbacks" "$tools" "$elapsed_ms" "$status" "$contract_valid" \
  "$memory_loaded" "$memory_chars" "$memory_write_count" "$memory_dedup_count" "$memory_compact_kept" \
  "$output_compact_runs" "$output_compact_removed" "$output_compact_compacted" "$output_compact_kept" \
  "$search_tool_count" "$search_query_count" "$search_source_count" "$search_reuse_hit" "$search_memory_write_count" \
  "$hook_name" "$pipeline_stage" "$workflow_selected" "$skill_id" "$skill_loaded_chars" "$skill_fallback" >> "$metrics_file"

echo "metrics:ok file=$metrics_file"
