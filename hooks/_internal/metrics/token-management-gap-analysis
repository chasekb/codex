    summary["pressure_low"] = summary["avg_pre_prompt_utilization"] <= policy["prompt_budget_low_utilization"]
    summary["adjustment_gap"] = bool(summary["pressure_high"] and summary["pre_prompt_adjustment_rate"] == 0)
    summary["estimate_gap"] = bool(abs(summary["avg_estimate_error_rate"]) >= 0.15)
    summary["calibration_gap"] = bool(summary["estimate_gap"] and abs(summary["avg_pre_prompt_estimate_scale"] - 1.0) < 0.01)
    summary["prompt_cache_gap"] = bool(summary["avg_prompt_cache_total_chars"] > 0 and summary["avg_prompt_cache_static_ratio"] < 0.5)
    summary["learning_gap"] = bool(
        summary["pressure_high"]
        and summary["learning_loaded_rate"] < 0.5
        and summary["playbook_loaded_rate"] < 0.5
    )
    summary["feedback_gap"] = bool(
        summary["pressure_high"]
        and (summary["contract_invalid_rate"] > 0 or summary["retry_rate"] > 0 or summary["fallback_rate"] > 0)
    )
    workflow_summaries.append(summary)

