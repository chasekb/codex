def read_policy(path):
    values = {}
    with open(path, "r", encoding="utf-8") as f:
        for raw in f:
            line = raw.strip()
            if not line or line.startswith("#") or ":" not in line:
                continue
            key, value = line.split(":", 1)
            values[key.strip()] = value.strip()
    return {
        "prompt_budget_high_utilization": float(values.get("prompt_budget_high_utilization", 0.85)),
        "prompt_budget_low_utilization": float(values.get("prompt_budget_low_utilization", 0.45)),
        "prompt_budget_adjustment_rate": float(values.get("prompt_budget_adjustment_rate", 0.5)),
    }

def load_json(path, default):
    try:
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
        return data if isinstance(data, (dict, list)) else default
    except Exception:
        return default

def parse_float(value, default=0.0):
    try:
        if value in ("", None):
            return default
        return float(value)
    except Exception:
        return default

def parse_int(value, default=0):
    try:
        if value in ("", None):
            return default
        return int(float(value))
    except Exception:
        return default

def parse_bool(value):
    return str(value).strip().lower() == "true"

def non_empty(value):
    return value not in ("", None)

