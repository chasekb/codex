#!/usr/bin/env bash
set -euo pipefail

metrics_file="${1:-outputs/token-metrics.csv}"
policy_file="${2:-MCP/budgets/tuning-policy.yaml}"
budgets_file="${3:-MCP/budgets/token-budgets.yaml}"
out_file="${4:-outputs/tuning-proposals.json}"
report_file="${5:-outputs/budget-report.md}"
report_json_file="${6:-outputs/budget-report.json}"
history_file="${7:-outputs/budget-history.jsonl}"

[[ -f "$metrics_file" ]] || { echo "tuning:error missing_metrics"; exit 1; }
[[ -f "$policy_file" ]] || { echo "tuning:error missing_policy"; exit 1; }
[[ -f "$budgets_file" ]] || { echo "tuning:error missing_budgets"; exit 1; }

mkdir -p outputs

python3 - <<'PY' "$metrics_file" "$policy_file" "$budgets_file" "$out_file" "$report_file" "$report_json_file" "$history_file"
import csv
import json
import re
import sys
from datetime import datetime, timezone

metrics_file, policy_file, budgets_file, out_file, report_file, report_json_file, history_file = sys.argv[1:]

def read_policy(path):
    p = {}
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            s = line.strip()
            if not s or s.startswith("#") or ":" not in s:
                continue
            k, v = s.split(":", 1)
            p[k.strip()] = v.strip()
    return {
        "mode": p.get("mode", "observe"),
        "min_samples": int(float(p.get("min_samples_per_workflow", "5"))),
        "max_shift": float(p.get("max_budget_shift_pct", "10")),
        "max_contract_invalid": float(p.get("max_contract_invalid_rate", "0.02")),
        "min_pass_rate": float(p.get("min_pass_rate", "0.95")),
        "max_retry_rate": float(p.get("max_retry_rate", "0.20")),
        "max_fallback_rate": float(p.get("max_fallback_rate", "0.20")),
        "prompt_budget_high_utilization": float(p.get("prompt_budget_high_utilization", "0.85")),
        "prompt_budget_low_utilization": float(p.get("prompt_budget_low_utilization", "0.45")),
        "prompt_budget_adjustment_rate": float(p.get("prompt_budget_adjustment_rate", "0.50")),
    }

def workflow_to_budget_profile(wf):
    mapping = {
        "plan-only": "plan",
        "request-standard": "implement",
        "implement-small": "implement",
        "debug-rca": "debug_rca",
        "verify": "verify",
        "retro": "plan",
    }
    return mapping.get(wf, wf)

def parse_budgets(path):
    current = {}
    profile = None
    in_budgets = False
    with open(path, "r", encoding="utf-8") as f:
        for line in f:
            if re.match(r"^budgets:\s*$", line):
                in_budgets = True
                continue
            if in_budgets and re.match(r"^[A-Za-z_]", line):
                # next top-level section
                break
            m_profile = re.match(r"^\s{2}([a-zA-Z0-9_]+):\s*$", line)
            if m_profile:
                profile = m_profile.group(1)
                current.setdefault(profile, {})
                continue
            m_val = re.match(r"^\s{4}([a-zA-Z0-9_]+):\s*([0-9.]+)\s*$", line)
            if m_val and profile:
                k, v = m_val.group(1), m_val.group(2)
                current[profile][k] = float(v)
    return current

policy = read_policy(policy_file)
budgets = parse_budgets(budgets_file)

stats = {}
with open(metrics_file, "r", encoding="utf-8") as f:
    reader = csv.DictReader(f)
    for r in reader:
        wf = r.get("workflow", "unknown")
        s = stats.setdefault(wf, {
            "n": 0,
            "pass": 0,
            "contract_bad": 0,
            "retry_sum": 0.0,
            "fallback_sum": 0.0,
            "total_tokens_sum": 0.0,
            "memory_chars_sum": 0.0,
            "learning_chars_sum": 0.0,
            "failure_history_chars_sum": 0.0,
            "playbook_chars_sum": 0.0,
            "search_hints_chars_sum": 0.0,
            "skill_chars_sum": 0.0,
            "pre_prompt_budget_soft_sum": 0.0,
            "pre_prompt_budget_hard_sum": 0.0,
            "pre_prompt_objective_chars_sum": 0.0,
            "pre_prompt_context_chars_sum": 0.0,
            "pre_prompt_est_tokens_sum": 0.0,
            "pre_prompt_utilization_sum": 0.0,
            "pre_prompt_margin_tokens_sum": 0.0,
            "pre_prompt_adjustment_count": 0,
        })
        s["n"] += 1
        if str(r.get("status", "")).lower() == "pass":
            s["pass"] += 1
        if str(r.get("contract_valid", "")).lower() != "true":
            s["contract_bad"] += 1
        s["retry_sum"] += float(r.get("retries", 0) or 0)
        s["fallback_sum"] += float(r.get("fallbacks", 0) or 0)
        s["total_tokens_sum"] += float(r.get("total_tokens", 0) or 0)
        s["memory_chars_sum"] += float(r.get("memory_chars", 0) or 0)
        s["learning_chars_sum"] += float(r.get("learning_chars", 0) or 0)
        s["failure_history_chars_sum"] += float(r.get("failure_history_chars", 0) or 0)
        s["playbook_chars_sum"] += float(r.get("playbook_chars", 0) or 0)
        s["search_hints_chars_sum"] += float(r.get("search_hints_chars", 0) or 0)
        s["skill_chars_sum"] += float(r.get("skill_loaded_chars", 0) or 0)
        s["pre_prompt_budget_soft_sum"] += float(r.get("pre_prompt_budget_soft", 0) or 0)
        s["pre_prompt_budget_hard_sum"] += float(r.get("pre_prompt_budget_hard", 0) or 0)
        s["pre_prompt_objective_chars_sum"] += float(r.get("pre_prompt_objective_chars", 0) or 0)
        s["pre_prompt_context_chars_sum"] += float(r.get("pre_prompt_context_chars", 0) or 0)
        s["pre_prompt_est_tokens_sum"] += float(r.get("pre_prompt_est_tokens", 0) or 0)
        s["pre_prompt_utilization_sum"] += float(r.get("pre_prompt_utilization", 0) or 0)
        s["pre_prompt_margin_tokens_sum"] += float(r.get("pre_prompt_margin_tokens", 0) or 0)
        if str(r.get("pre_prompt_adjustment_warranted", "")).lower() == "true":
            s["pre_prompt_adjustment_count"] += 1

proposals = []
workflow_rows = []
for wf, s in stats.items():
    n = s["n"]
    if n < policy["min_samples"]:
        continue

    pass_rate = s["pass"] / n
    contract_invalid = s["contract_bad"] / n
    retry_rate = s["retry_sum"] / n
    fallback_rate = s["fallback_sum"] / n
    avg_tokens = s["total_tokens_sum"] / n
    avg_memory_chars = s["memory_chars_sum"] / n
    avg_learning_chars = s["learning_chars_sum"] / n
    avg_failure_history_chars = s["failure_history_chars_sum"] / n
    avg_playbook_chars = s["playbook_chars_sum"] / n
    avg_search_hints_chars = s["search_hints_chars_sum"] / n
    avg_skill_chars = s["skill_chars_sum"] / n
    avg_pre_prompt_budget_soft = s["pre_prompt_budget_soft_sum"] / n
    avg_pre_prompt_budget_hard = s["pre_prompt_budget_hard_sum"] / n
    avg_pre_prompt_objective_chars = s["pre_prompt_objective_chars_sum"] / n
    avg_pre_prompt_context_chars = s["pre_prompt_context_chars_sum"] / n
    avg_pre_prompt_est_tokens = s["pre_prompt_est_tokens_sum"] / n
    avg_pre_prompt_utilization = s["pre_prompt_utilization_sum"] / n
    avg_pre_prompt_margin_tokens = s["pre_prompt_margin_tokens_sum"] / n
    pre_prompt_adjustment_rate = s["pre_prompt_adjustment_count"] / n

    profile = workflow_to_budget_profile(wf)
    if profile not in budgets:
        continue

    profile_cfg = budgets[profile]
    proposed_changes = {}

    healthy = (
        pass_rate >= policy["min_pass_rate"] and
        contract_invalid <= policy["max_contract_invalid"] and
        retry_rate <= policy["max_retry_rate"] and
        fallback_rate <= policy["max_fallback_rate"]
    )

    shift = min(policy["max_shift"], 5.0) / 100.0
    prompt_pressure_high = (
        avg_pre_prompt_utilization >= policy["prompt_budget_high_utilization"]
        or pre_prompt_adjustment_rate >= policy["prompt_budget_adjustment_rate"]
    )
    prompt_pressure_low = (
        avg_pre_prompt_utilization <= policy["prompt_budget_low_utilization"]
        and pre_prompt_adjustment_rate == 0
    )

    if healthy and prompt_pressure_high:
        if "input_soft" in profile_cfg:
            proposed_changes["input_soft"] = max(1, int(round(profile_cfg["input_soft"] * (1 + shift))))
        if "memory_read_soft" in profile_cfg and avg_memory_chars > (profile_cfg["memory_read_soft"] * 0.85):
            proposed_changes["memory_read_soft"] = max(1, int(round(profile_cfg["memory_read_soft"] * (1 + shift))))
        if "learning_read_soft" in profile_cfg and avg_learning_chars > (profile_cfg["learning_read_soft"] * 0.85):
            proposed_changes["learning_read_soft"] = max(1, int(round(profile_cfg["learning_read_soft"] * (1 + shift))))
        if "skill_read_soft" in profile_cfg and avg_skill_chars > (profile_cfg["skill_read_soft"] * 0.85):
            proposed_changes["skill_read_soft"] = max(1, int(round(profile_cfg["skill_read_soft"] * (1 + shift))))
        if "skill_read_soft" in profile_cfg and avg_playbook_chars > 350:
            proposed_changes["skill_read_soft"] = max(1, int(round(profile_cfg["skill_read_soft"] * (1 + shift))))
    elif healthy and (avg_tokens > 1000 or prompt_pressure_low):
        for k in ("input_soft", "output_soft"):
            if k in profile_cfg:
                proposed_changes[k] = max(1, int(round(profile_cfg[k] * (1 - shift))))

    if healthy and avg_memory_chars < 120 and "memory_read_soft" in profile_cfg:
        proposed_changes["memory_read_soft"] = max(1, int(round(profile_cfg["memory_read_soft"] * (1 - shift))))

    if healthy and avg_learning_chars < 120 and "learning_read_soft" in profile_cfg:
        proposed_changes["learning_read_soft"] = max(1, int(round(profile_cfg["learning_read_soft"] * (1 - shift))))

    if healthy and avg_skill_chars < 220 and "skill_read_soft" in profile_cfg:
        proposed_changes["skill_read_soft"] = max(1, int(round(profile_cfg["skill_read_soft"] * (1 - shift))))

    if proposed_changes:
        proposals.append({
            "workflow": wf,
            "budget_profile": profile,
            "changes": proposed_changes,
            "evidence": {
                "samples": n,
                "pass_rate": round(pass_rate, 4),
                "contract_invalid_rate": round(contract_invalid, 4),
                "retry_rate": round(retry_rate, 4),
                "fallback_rate": round(fallback_rate, 4),
                "avg_total_tokens": round(avg_tokens, 2),
                "avg_memory_chars": round(avg_memory_chars, 2),
                "avg_learning_chars": round(avg_learning_chars, 2),
                "avg_failure_history_chars": round(avg_failure_history_chars, 2),
                "avg_playbook_chars": round(avg_playbook_chars, 2),
                "avg_search_hints_chars": round(avg_search_hints_chars, 2),
                "avg_skill_loaded_chars": round(avg_skill_chars, 2),
                "avg_pre_prompt_budget_soft": round(avg_pre_prompt_budget_soft, 2),
                "avg_pre_prompt_budget_hard": round(avg_pre_prompt_budget_hard, 2),
                "avg_pre_prompt_objective_chars": round(avg_pre_prompt_objective_chars, 2),
                "avg_pre_prompt_context_chars": round(avg_pre_prompt_context_chars, 2),
                "avg_pre_prompt_est_tokens": round(avg_pre_prompt_est_tokens, 2),
                "avg_pre_prompt_utilization": round(avg_pre_prompt_utilization, 4),
                "avg_pre_prompt_margin_tokens": round(avg_pre_prompt_margin_tokens, 2),
                "pre_prompt_adjustment_rate": round(pre_prompt_adjustment_rate, 4),
            }
        })

    workflow_rows.append({
        "workflow": wf,
        "budget_profile": profile,
        "samples": n,
        "pass_rate": round(pass_rate, 4),
        "contract_invalid_rate": round(contract_invalid, 4),
        "retry_rate": round(retry_rate, 4),
        "fallback_rate": round(fallback_rate, 4),
        "avg_total_tokens": round(avg_tokens, 2),
        "avg_memory_chars": round(avg_memory_chars, 2),
        "avg_learning_chars": round(avg_learning_chars, 2),
        "avg_failure_history_chars": round(avg_failure_history_chars, 2),
        "avg_playbook_chars": round(avg_playbook_chars, 2),
        "avg_search_hints_chars": round(avg_search_hints_chars, 2),
        "avg_skill_loaded_chars": round(avg_skill_chars, 2),
        "avg_pre_prompt_budget_soft": round(avg_pre_prompt_budget_soft, 2),
        "avg_pre_prompt_budget_hard": round(avg_pre_prompt_budget_hard, 2),
        "avg_pre_prompt_objective_chars": round(avg_pre_prompt_objective_chars, 2),
        "avg_pre_prompt_context_chars": round(avg_pre_prompt_context_chars, 2),
        "avg_pre_prompt_est_tokens": round(avg_pre_prompt_est_tokens, 2),
        "avg_pre_prompt_utilization": round(avg_pre_prompt_utilization, 4),
        "avg_pre_prompt_margin_tokens": round(avg_pre_prompt_margin_tokens, 2),
        "pre_prompt_adjustment_rate": round(pre_prompt_adjustment_rate, 4),
        "prompt_pressure_high": bool(prompt_pressure_high),
        "prompt_pressure_low": bool(prompt_pressure_low),
        "healthy": bool(healthy),
        "proposal_emitted": bool(proposed_changes),
    })

result = {
    "generated_at": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
    "mode": policy["mode"],
    "proposal_count": len(proposals),
    "proposals": proposals,
}

with open(out_file, "w", encoding="utf-8") as f:
    json.dump(result, f, separators=(",", ":"))

workflow_summary = sorted(workflow_rows, key=lambda r: (r["proposal_emitted"], r["avg_pre_prompt_utilization"]), reverse=True)
report_data = {
    "generated_at": result["generated_at"],
    "mode": result["mode"],
    "proposal_count": result["proposal_count"],
    "policy": {
        "min_samples": policy["min_samples"],
        "max_shift_pct": policy["max_shift"],
        "prompt_budget_high_utilization": policy["prompt_budget_high_utilization"],
        "prompt_budget_low_utilization": policy["prompt_budget_low_utilization"],
        "prompt_budget_adjustment_rate": policy["prompt_budget_adjustment_rate"],
    },
    "workflow_summary": workflow_summary,
    "proposals": proposals,
}

with open(report_json_file, "w", encoding="utf-8") as f:
    json.dump(report_data, f, separators=(",", ":"))

with open(history_file, "a", encoding="utf-8") as f:
    f.write(json.dumps(report_data, separators=(",", ":")) + "\n")

report_lines = [
    "# Budget Report",
    "",
    f"Generated: {result['generated_at']}",
    f"Mode: {result['mode']}",
    f"Proposal count: {result['proposal_count']}",
    "",
    "## Policy",
    f"- min samples: {policy['min_samples']}",
    f"- max shift pct: {policy['max_shift']}",
    f"- high utilization: {policy['prompt_budget_high_utilization']}",
    f"- low utilization: {policy['prompt_budget_low_utilization']}",
    f"- adjustment rate: {policy['prompt_budget_adjustment_rate']}",
    "",
    "## Workflow Summary",
]
for row in workflow_summary:
    report_lines.extend([
        f"- `{row['workflow']}` ({row['budget_profile']}): samples={row['samples']} pass_rate={row['pass_rate']} util={row['avg_pre_prompt_utilization']} margin={row['avg_pre_prompt_margin_tokens']} pressure_high={str(row['prompt_pressure_high']).lower()} pressure_low={str(row['prompt_pressure_low']).lower()} proposal={str(row['proposal_emitted']).lower()}",
    ])

with open(report_file, "w", encoding="utf-8") as f:
    f.write("\n".join(report_lines) + "\n")

print(f"tuning:proposals file={out_file} count={len(proposals)}")
print(f"tuning:report file={report_file}")
print(f"tuning:report_json file={report_json_file}")
print(f"tuning:history file={history_file}")
PY
