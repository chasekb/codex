#!/usr/bin/env bash
set -euo pipefail

find_repo_root() {
  local dir="$1"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/hooks.json" && -d "$dir/skills" && -d "$dir/rules" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname -- "$dir")"
  done
  return 1
}

ROOT="$(find_repo_root "$(cd -- "$(dirname -- "$0")" && pwd)")"
OUT_DIR="$ROOT/outputs"

mkdir -p "$OUT_DIR"
chmod u+rwx "$OUT_DIR" || true

required_files=(
  "hook-errors.log"
  "hook-file-error.log"
  "hook-events.log"
  "hook-file-logger.log"
  "hook-runtime-state.json"
  "hook-token-debug.log"
  "token-metrics.csv"
  "token-baselines.csv"
  "tuning-history.csv"
  "tuning-proposals.json"
  "budget-report.md"
  "budget-report.json"
  "budget-compare.md"
  "budget-compare.json"
  "budget-history.jsonl"
  "tuning-open-request.md"
  "tuning-open-request.json"
  "budget-summary.md"
  "budget-summary.json"
  "external-skill-discovery.md"
  "external-skill-discovery.json"
  "external-origin-intake.md"
  "external-origin-intake.json"
  "external-origin-provenance.jsonl"
  "external-origin-validation.jsonl"
  "external-origin-drift.jsonl"
  "canary-report.json"
  "canary-token-budgets.yaml"
)

for file in "${required_files[@]}"; do
  target="$OUT_DIR/$file"
  touch "$target"
  chmod u+rw "$target" || true
done

probe="$(mktemp "$OUT_DIR/.write-test.XXXXXX")"
echo "ok" > "$probe"
rm -f "$probe"

echo "outputs:writable dir=$OUT_DIR"
