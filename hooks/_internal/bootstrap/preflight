  "plugins/nelson/rules/registry.yaml"
  "plugins/nelson/workflows/registry.yaml"
  "validation/codex-runtime-eval-cases.jsonl"
)

bootstrap_file() {
  local path="$1"
  local content="$2"
  if [[ ! -f "$path" ]]; then
    mkdir -p "$(dirname "$path")"
    printf '%s\n' "$content" > "$path"
  fi
}

check_superpowers_submodule() {
  local configured_path
  configured_path="$(git -C "$root" config -f "$root/.gitmodules" --get submodule.superpowers.path 2>/dev/null || true)"
  [[ "$configured_path" == "superpowers" ]] || return 0

  local status_line
  status_line="$(git -C "$root" submodule status -- superpowers 2>/dev/null | head -n1 || true)"
  case "$status_line" in
    " "*) ;;
    "-"*)
      echo "missing: superpowers submodule is not initialized; run: git submodule update --init --recursive superpowers"
      exit 1
      ;;
    "+"*)
      echo "stale: superpowers submodule is checked out at a different commit; run: git submodule update --init --recursive superpowers"
      exit 1
      ;;
    "U"*)
      echo "broken: superpowers submodule has unresolved conflicts; resolve the submodule and retry"
      exit 1
      ;;
    "")
      echo "missing: superpowers submodule is not initialized; run: git submodule update --init --recursive superpowers"
      exit 1
      ;;
    *)
      echo "missing: superpowers submodule is not initialized; run: git submodule update --init --recursive superpowers"
      exit 1
      ;;
  esac

  if [[ ! -f "$root/superpowers/skills/registry.yaml" ]]; then
    echo "missing: $root/superpowers/skills/registry.yaml (run: git submodule update --init --recursive superpowers)"
    exit 1
  fi
}

check_superpowers_submodule

for rel in "${required_rel[@]}"; do
  f="$root/$rel"
  if [[ ! -f "$f" ]]; then
    case "$rel" in
      "MCP/memory/session.json")
        bootstrap_file "$f" '{"version":1,"max_bytes":2048,"task":{"objective":"","constraints":[],"active_files":[],"latest_decisions":[],"blockers":[]},"updated_at":""}'
        ;;
      "MCP/memory/facts.jsonl"|"MCP/memory/decisions.jsonl")
        bootstrap_file "$f" ""
        ;;
      "MCP/memory/index.yaml")
        bootstrap_file "$f" 'version: 1'
        ;;
      *)
        echo "missing: $f"
        exit 1
        ;;
    esac
  fi
done

required_abs=(
  "$root/skills/registry.yaml"
)

if [[ -d "$root/superpowers" ]]; then
  required_rel+=("superpowers/skills/registry.yaml")
fi

for f in "${required_abs[@]}"; do
  [[ -f "$f" ]] || { echo "missing: $f"; exit 1; }
done

"$script_dir/ensure-outputs-writable" >/dev/null

echo "preflight:ok"
