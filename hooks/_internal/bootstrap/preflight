#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "$0")" && pwd)"

find_repo_root() {
  local dir="$1"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/hooks.json" && -d "$dir/skills" && -d "$dir/rules" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname -- "$dir")"
  done
  return 1
}

root="$(find_repo_root "$script_dir")"

required_rel=(
  "MCP/defaults.yaml"
  "MCP/routing.yaml"
  "MCP/budgets/token-budgets.yaml"
  "MCP/budgets/tuning-policy.yaml"
  "MCP/memory/session.json"
  "MCP/memory/facts.jsonl"
  "MCP/memory/decisions.jsonl"
  "MCP/memory/index.yaml"
  "MCP/backlog/backlog.json"
  "workflows/index.yaml"
  "workflows/pipelines/request-standard.yaml"
  "workflows/pipelines/retro.yaml"
  "workflows/pipelines/project-backlog-management.yaml"
  "workflows/pipelines/backlog-triage.yaml"
  "workflows/pipelines/recommendation-to-task.yaml"
  "workflows/pipelines/weekly-backlog-review.yaml"
  "workflows/pipelines/review-closeout.yaml"
  "workflows/pipelines/project-insights.yaml"
  "workflows/pipelines/stale-item-review.yaml"
  "workflows/pipelines/issue-writing.yaml"
  "workflows/pipelines/debug-deep-dive.yaml"
  "workflows/pipelines/multi-task-implementation.yaml"
  "workflows/pipelines/skill-maintenance.yaml"
  "workflows/pipelines/skill-promotion.yaml"
  "workflows/shared/output-handling.yaml"
  "workflows/shared/output-contracts.yaml"
  "hooks/_internal/routing/select-skill"
  "hooks/_internal/routing/select-skill-catalog"
  "hooks/_internal/routing/skill_registry.py"
  "hooks/_internal/routing/select-command"
  "hooks/_internal/routing/select-command-catalog"
  "hooks/_internal/routing/command_registry.py"
  "hooks/_internal/routing/select-agent"
  "hooks/_internal/routing/select-agent-catalog"
  "hooks/_internal/routing/agent_registry.py"
  "hooks/_internal/routing/sync-installed-skills-registry"
  "hooks/_internal/routing/discover-external-skills"
  "hooks/_internal/routing/load-skill"
  "hooks/_internal/routing/validate-skill"
  "hooks/_internal/memory/load-memory"
  "hooks/_internal/memory/load-learning-context"
  "hooks/_internal/memory/load-failure-history"
  "hooks/_internal/routing/load-playbook-snippet"
