#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "$0")" && pwd)"

find_repo_root() {
  local dir="$1"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/hooks.json" && -d "$dir/skills" && -d "$dir/rules" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname -- "$dir")"
  done
  return 1
}

root="$(find_repo_root "$script_dir")"

required_rel=(
  "MCP/defaults.yaml"
  "MCP/routing.yaml"
  "MCP/budgets/token-budgets.yaml"
  "MCP/budgets/tuning-policy.yaml"
  "MCP/memory/session.json"
  "MCP/memory/facts.jsonl"
  "MCP/memory/decisions.jsonl"
  "MCP/memory/index.yaml"
  "MCP/backlog/backlog.json"
  "workflows/index.yaml"
  "workflows/pipelines/request-standard.yaml"
  "workflows/pipelines/retro.yaml"
  "workflows/pipelines/project-backlog-management.yaml"
  "workflows/pipelines/review-closeout.yaml"
  "workflows/pipelines/multi-task-implementation.yaml"
  "workflows/shared/output-handling.yaml"
  "workflows/shared/output-contracts.yaml"
  "hooks/_internal/routing/select-skill"
  "hooks/_internal/routing/select-skill-catalog"
  "hooks/_internal/routing/skill_registry.py"
  "hooks/_internal/routing/sync-installed-skills-registry"
  "hooks/_internal/routing/discover-external-skills"
  "hooks/_internal/routing/load-skill"
  "hooks/_internal/routing/validate-skill"
  "hooks/_internal/memory/load-memory"
  "hooks/_internal/memory/load-learning-context"
  "hooks/_internal/memory/load-failure-history"
  "hooks/_internal/routing/load-playbook-snippet"
  "hooks/_internal/memory/load-search-hints"
  "hooks/_internal/memory/write-memory"
  "hooks/_internal/memory/compact-memory"
  "hooks/_internal/backlog/backlog-manager"
  "hooks/_internal/metrics/tune-from-metrics"
  "hooks/_internal/metrics/load-budget-controller"
  "hooks/_internal/metrics/apply-tuning-canary"
  "hooks/_internal/metrics/promote-tuning"
  "hooks/_internal/metrics/rollback-tuning"
  "hooks/_internal/logging/file-logger"
  "hooks/_internal/logging/event-logger"
  "hooks/_internal/bootstrap/ensure-outputs-writable"
  "hooks/_internal/output/compact-outputs"
)

bootstrap_file() {
  local path="$1"
  local content="$2"
  if [[ ! -f "$path" ]]; then
    mkdir -p "$(dirname "$path")"
    printf '%s\n' "$content" > "$path"
  fi
}

for rel in "${required_rel[@]}"; do
  f="$root/$rel"
  if [[ ! -f "$f" ]]; then
    case "$rel" in
      "MCP/memory/session.json")
        bootstrap_file "$f" '{"version":1,"max_bytes":2048,"task":{"objective":"","constraints":[],"active_files":[],"latest_decisions":[],"blockers":[]},"updated_at":""}'
        ;;
      "MCP/memory/facts.jsonl"|"MCP/memory/decisions.jsonl")
        bootstrap_file "$f" ""
        ;;
      "MCP/memory/index.yaml")
        bootstrap_file "$f" 'version: 1'
        ;;
      *)
        echo "missing: $f"
        exit 1
        ;;
    esac
  fi
done

required_abs=(
  "$root/skills/registry.yaml"
)

if [[ -d "$root/superpowers" ]]; then
  required_rel+=("superpowers/skills/registry.yaml")
fi

for f in "${required_abs[@]}"; do
  [[ -f "$f" ]] || { echo "missing: $f"; exit 1; }
done

"$script_dir/ensure-outputs-writable" >/dev/null

echo "preflight:ok"
