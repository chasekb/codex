def parse_budget_controller_metrics(output):
    report = {
        "loaded": 0,
        "prompt_scale": 1.0,
        "memory_scale": 1.0,
        "learning_scale": 1.0,
        "failure_scale": 1.0,
        "playbook_scale": 1.0,
        "search_scale": 1.0,
        "skill_scale": 1.0,
        "reason": "",
    }
    for line in output.splitlines():
        if line.startswith("{"):
            try:
                parsed = json.loads(line)
                if isinstance(parsed, dict):
                    report["loaded"] = to_int(parsed.get("budget_controller_loaded", report["loaded"]))
                    report["prompt_scale"] = to_float(parsed.get("prompt_scale", report["prompt_scale"]), report["prompt_scale"])
                    report["memory_scale"] = to_float(parsed.get("memory_scale", report["memory_scale"]), report["memory_scale"])
                    report["learning_scale"] = to_float(parsed.get("learning_scale", report["learning_scale"]), report["learning_scale"])
                    report["failure_scale"] = to_float(parsed.get("failure_scale", report["failure_scale"]), report["failure_scale"])
                    report["playbook_scale"] = to_float(parsed.get("playbook_scale", report["playbook_scale"]), report["playbook_scale"])
                    report["search_scale"] = to_float(parsed.get("search_scale", report["search_scale"]), report["search_scale"])
                    report["skill_scale"] = to_float(parsed.get("skill_scale", report["skill_scale"]), report["skill_scale"])
                    report["reason"] = text(parsed.get("reason", report["reason"]))
            except Exception:
                pass
        if line.startswith("budget_controller:metrics"):
            report["loaded"] = parse_kv_metric(line, "loaded")
            report["prompt_scale"] = to_float(re.search(r"\bprompt_scale=([0-9.]+)", line).group(1), 1.0) if re.search(r"\bprompt_scale=([0-9.]+)", line) else 1.0
            report["memory_scale"] = to_float(re.search(r"\bmemory_scale=([0-9.]+)", line).group(1), 1.0) if re.search(r"\bmemory_scale=([0-9.]+)", line) else 1.0
            report["learning_scale"] = to_float(re.search(r"\blearning_scale=([0-9.]+)", line).group(1), 1.0) if re.search(r"\blearning_scale=([0-9.]+)", line) else 1.0
            report["failure_scale"] = to_float(re.search(r"\bfailure_scale=([0-9.]+)", line).group(1), 1.0) if re.search(r"\bfailure_scale=([0-9.]+)", line) else 1.0
            report["playbook_scale"] = to_float(re.search(r"\bplaybook_scale=([0-9.]+)", line).group(1), 1.0) if re.search(r"\bplaybook_scale=([0-9.]+)", line) else 1.0
            report["search_scale"] = to_float(re.search(r"\bsearch_scale=([0-9.]+)", line).group(1), 1.0) if re.search(r"\bsearch_scale=([0-9.]+)", line) else 1.0
            report["skill_scale"] = to_float(re.search(r"\bskill_scale=([0-9.]+)", line).group(1), 1.0) if re.search(r"\bskill_scale=([0-9.]+)", line) else 1.0
    return report


