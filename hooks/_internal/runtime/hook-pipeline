def read_tuning_mode(policy_path):
    try:
        with open(policy_path, "r", encoding="utf-8") as f:
            for line in f:
                s = line.strip()
                if not s or s.startswith("#"):
                    continue
                if s.startswith("mode:"):
                    return s.split(":", 1)[1].strip().lower()
    except Exception:
        pass
    return "observe"


def main():
    hook_name = sys.argv[1] if len(sys.argv) > 1 else "unknown"
    raw = sys.stdin.read()
    try:
        payload = json.loads(raw) if raw.strip() else {}
    except Exception:
        payload = {}

    state = load_state()
    state["updated_at"] = now_iso()
    state["session"]["updated_at"] = state["updated_at"]

    if hook_name in ("TaskStart", "TaskResume"):
        if hook_name == "TaskStart":
            # New task start gets a clean run-state snapshot.
            fresh = default_state()
            state["counters"] = fresh["counters"]
            state["tokens"] = fresh["tokens"]
            state["metrics"] = fresh["metrics"]
            state["tools_used"] = []
            state["files_touched"] = []
            state["session"]["started_at"] = state["updated_at"]

        task_class = first(
            nested(payload, ["task", "class"]),
            nested(payload, [hook_name[0].lower() + hook_name[1:], "taskClass"]),
            payload.get("taskClass"),
            "general",
        )
        confidence = to_float(
            first(
                nested(payload, ["classification", "confidence"]),
                nested(payload, [hook_name[0].lower() + hook_name[1:], "confidence"]),
                payload.get("confidence"),
                0.0,
            ),
            0.0,
        )
        objective = text(
            first(
                nested(payload, ["task", "objective"]),
                nested(payload, [hook_name[0].lower() + hook_name[1:], "prompt"]),
                payload.get("prompt"),
                payload.get("message"),
                state["session"].get("objective", ""),
            )
        )

        keywords = " ".join(objective.split()[:20])
        _, wf_out = run_internal("select-workflow", [str(task_class), f"{confidence:.3f}", keywords, ROOT])
        workflow = text(wf_out.splitlines()[-1] if wf_out.splitlines() else "unknown") or "unknown"
        output_contract = resolve_output_contract(workflow)
        _, skill_out = run_internal("select-skill", [str(task_class), f"{confidence:.3f}", keywords, ROOT])
        skill_lines = [l for l in skill_out.splitlines() if text(l)]
        skill_id = text(skill_lines[-1]) if skill_lines else "tool-minimization"
        skill_fallback = any("fallback=true" in l for l in skill_lines)

        external_skill_report = {}
        external_skill_mode = text(os.environ.get("CODEX_EXTERNAL_SKILL_DISCOVERY", "")).lower()
        external_skill_enabled = external_skill_mode in {"1", "true", "yes", "on", "discover", "install", "auto"}
        if (
            skill_id in {"tool-minimization", "plan-verify-execute", "context-compaction"}
            and external_skill_enabled
        ):
            _, discover_out = run_internal(
                "discover-external-skills",
                [str(task_class), f"{confidence:.3f}", keywords, skill_id, ROOT],
            )
            external_skill_report = parse_external_skill_discovery(discover_out)
            state["metrics"]["external_skill_discovery_runs"] += 1
            state["metrics"]["external_skill_install_attempts"] += int(bool(external_skill_report.get("attempted_install")))
            state["metrics"]["external_skill_install_successes"] += int(bool(external_skill_report.get("installed")))
            if external_skill_report.get("installed"):
                _, skill_out = run_internal("select-skill", [str(task_class), f"{confidence:.3f}", keywords, ROOT])
                skill_lines = [l for l in skill_out.splitlines() if text(l)]
                skill_id = text(skill_lines[-1]) if skill_lines else skill_id
                skill_fallback = any("fallback=true" in l for l in skill_lines)
                append_event_log(
                    "external_skill_installed",
                    hook_name,
                    workflow=workflow,
                    skill=skill_id,
                    stage="selection",
                    status="installed",
                    details=text(external_skill_report.get("selected", {}).get("name", "")),
                    )

        backlog_report = {}
        if workflow == "project-backlog-management":
            _, backlog_out = run_internal("backlog-manager", ["status"])
            backlog_report = parse_backlog_metrics(backlog_out)
            state["metrics"]["backlog_loaded"] = backlog_report["loaded"]
            state["metrics"]["backlog_open_recommendations"] = backlog_report["open_recommendations"]
            state["metrics"]["backlog_open_tasks"] = backlog_report["open_tasks"]
            state["metrics"]["backlog_completed_tasks"] = backlog_report["completed_tasks"]
            append_event_log(
                "backlog_loaded",
                hook_name,
                workflow=workflow,
                skill=skill_id,
                stage="preprompt",
                status="loaded",
                details=(
                    f"open_recommendations={backlog_report['open_recommendations']} "
                    f"open_tasks={backlog_report['open_tasks']}"
                ),
            )

        _, load_skill_out = run_internal("load-skill", [skill_id, "metadata", "700", resolve_skills_registry()])
        skill_loaded_chars = parse_skill_loaded_chars(load_skill_out)

        _, controller_out = run_internal(
            "load-budget-controller",
            [workflow, str(task_class), "outputs/budget-summary.json", "MCP/budgets/tuning-policy.yaml", "MCP/budgets/token-budgets.yaml"],
        )
        budget_controller = parse_budget_controller_metrics(controller_out)

        token_defaults = load_token_defaults()
        prompt_budget_chars = max(1, (token_defaults["max_input_tokens"] - token_defaults["reserve_output_tokens"]) * 4)
        remaining_prompt_chars = max(0, prompt_budget_chars - len(objective) - skill_loaded_chars)

        memory_max_chars = prompt_stage_char_cap(remaining_prompt_chars, int(500 * budget_controller["memory_scale"]), int(180 * budget_controller["memory_scale"]), 0.24 * budget_controller["memory_scale"])
        memory_max_results = prompt_stage_result_cap(remaining_prompt_chars)
        _, load_mem_out = run_internal(
            "load-memory",
            [str(task_class), keywords, str(memory_max_chars), str(memory_max_results), "MCP/memory"],
        )
        mem_loaded, mem_chars, mem_results = parse_memory_load_metrics(load_mem_out)

        context_keywords_parts = [keywords]
        if mem_results and isinstance(mem_results[0], dict) and mem_results[0].get("type") == "session":
            session_focus = []
            for key in ("objective", "constraints", "active_files", "latest_decisions", "blockers"):
                value = mem_results[0].get(key, [])
                if isinstance(value, list):
                    session_focus.extend([text(item) for item in value if text(item)])
                elif text(value):
                    session_focus.append(text(value))
            if session_focus:
                context_keywords_parts.append(" ".join(session_focus[:12]))
        context_keywords = " ".join(part for part in context_keywords_parts if text(part))

        remaining_prompt_chars = max(0, remaining_prompt_chars - mem_chars)
        learning_max_chars = prompt_stage_char_cap(remaining_prompt_chars, int(500 * budget_controller["learning_scale"]), int(150 * budget_controller["learning_scale"]), 0.18 * budget_controller["learning_scale"])
        learning_max_results = prompt_stage_result_cap(remaining_prompt_chars)
        _, load_learning_out = run_internal(
            "load-learning-context",
            [str(task_class), context_keywords, str(learning_max_chars), str(learning_max_results), ".learnings"],
        )
        learning_loaded, learning_chars, learning_results = parse_learning_load_metrics(load_learning_out)
        remaining_prompt_chars = max(0, remaining_prompt_chars - learning_chars)

        failure_max_chars = prompt_stage_char_cap(remaining_prompt_chars, int(500 * budget_controller["failure_scale"]), int(140 * budget_controller["failure_scale"]), 0.16 * budget_controller["failure_scale"])
        failure_max_results = prompt_stage_result_cap(remaining_prompt_chars)
        _, load_failure_out = run_internal(
            "load-failure-history",
            [
                str(task_class),
                context_keywords,
                str(failure_max_chars),
                str(failure_max_results),
                "outputs/hook-errors.log",
                "outputs/hook-file-error.log",
            ],
        )
        failure_history_loaded, failure_history_chars, failure_results = parse_failure_history_metrics(load_failure_out)
        remaining_prompt_chars = max(0, remaining_prompt_chars - failure_history_chars)

        playbook_max_chars = prompt_stage_char_cap(remaining_prompt_chars, int(700 * budget_controller["playbook_scale"]), int(180 * budget_controller["playbook_scale"]), 0.20 * budget_controller["playbook_scale"])
        _, workflow_playbook_out = run_internal(
            "load-playbook-snippet",
            ["workflow", workflow, str(playbook_max_chars), ROOT],
        )
        workflow_playbook_loaded, workflow_playbook_chars, workflow_playbook_results = parse_playbook_metrics(workflow_playbook_out)
        remaining_prompt_chars = max(0, remaining_prompt_chars - workflow_playbook_chars)
        skill_playbook_max_chars = prompt_stage_char_cap(remaining_prompt_chars, int(700 * budget_controller["skill_scale"]), int(180 * budget_controller["skill_scale"]), 0.20 * budget_controller["skill_scale"])
        _, skill_playbook_out = run_internal(
            "load-playbook-snippet",
            ["skill", skill_id, str(skill_playbook_max_chars), ROOT, resolve_skills_registry()],
        )
        skill_playbook_loaded, skill_playbook_chars, skill_playbook_results = parse_playbook_metrics(skill_playbook_out)
        playbook_loaded = workflow_playbook_loaded + skill_playbook_loaded
        playbook_chars = workflow_playbook_chars + skill_playbook_chars
        playbook_results = workflow_playbook_results + skill_playbook_results
        remaining_prompt_chars = max(0, remaining_prompt_chars - skill_playbook_chars)

        search_hint_max_chars = prompt_stage_char_cap(remaining_prompt_chars, int(500 * budget_controller["search_scale"]), int(120 * budget_controller["search_scale"]), 0.12 * budget_controller["search_scale"])
        search_hint_max_results = prompt_stage_result_cap(remaining_prompt_chars)
        _, search_hint_out = run_internal(
            "load-search-hints",
            [str(task_class), context_keywords, str(search_hint_max_chars), str(search_hint_max_results), "MCP/memory"],
        )
        search_hint_loaded, search_hint_chars, search_hint_results = parse_search_hints_metrics(search_hint_out)
        pre_prompt_metrics = build_pre_prompt_metrics(objective, mem_chars, learning_chars, failure_history_chars, playbook_chars, search_hint_chars, skill_loaded_chars)

        state["session"].update(
            {
                "status": "running",
                "started_at": state["session"].get("started_at") or now_iso(),
                "hook_name": hook_name,
                "task_class": str(task_class),
                "workflow": workflow,
                "output_contract": output_contract,
                "skill_id": skill_id,
                "external_skill_id": text(external_skill_report.get("selected", {}).get("name", "")),
                "external_skill_source": text(external_skill_report.get("selected", {}).get("source", "")),
                "confidence": confidence,
                "objective": objective,
            }
        )
        state["metrics"]["memory_loaded"] = mem_loaded
        state["metrics"]["memory_chars"] = mem_chars
        state["metrics"]["learning_loaded"] = learning_loaded
        state["metrics"]["learning_chars"] = learning_chars
        state["metrics"]["failure_history_loaded"] = failure_history_loaded
        state["metrics"]["failure_history_chars"] = failure_history_chars
        state["metrics"]["playbook_loaded"] = playbook_loaded
        state["metrics"]["playbook_chars"] = playbook_chars
        state["metrics"]["search_hints_loaded"] = search_hint_loaded
        state["metrics"]["search_hints_chars"] = search_hint_chars
        state["metrics"]["budget_controller_loaded"] = budget_controller["loaded"]
        state["metrics"]["budget_controller_prompt_scale"] = budget_controller["prompt_scale"]
        state["metrics"]["budget_controller_memory_scale"] = budget_controller["memory_scale"]
        state["metrics"]["budget_controller_learning_scale"] = budget_controller["learning_scale"]
        state["metrics"]["budget_controller_failure_scale"] = budget_controller["failure_scale"]
        state["metrics"]["budget_controller_playbook_scale"] = budget_controller["playbook_scale"]
        state["metrics"]["budget_controller_search_scale"] = budget_controller["search_scale"]
        state["metrics"]["budget_controller_skill_scale"] = budget_controller["skill_scale"]
        state["metrics"]["search_reuse_hit"] = search_reuse_hits(mem_results, objective)
        state["metrics"]["skill_loaded_chars"] = skill_loaded_chars
        state["metrics"]["skill_fallback"] = bool(skill_fallback)
        state["metrics"].update(pre_prompt_metrics)
        state["metrics"]["external_skill_id"] = text(external_skill_report.get("selected", {}).get("name", ""))
        state["metrics"]["external_skill_source"] = text(external_skill_report.get("selected", {}).get("source", ""))
        if playbook_results:
            append_event_log(
                "playbook_loaded",
                hook_name,
                workflow=workflow,
                skill=skill_id,
                stage="preprompt",
                status="loaded",
                details=f"items={len(playbook_results)} chars={playbook_chars}",
            )
        if search_hint_results:
            append_event_log(
                "search_hints_loaded",
                hook_name,
                workflow=workflow,
                skill=skill_id,
                stage="preprompt",
                status="loaded",
                details=f"items={len(search_hint_results)} chars={search_hint_chars}",
            )
        if budget_controller["loaded"]:
            append_event_log(
                "budget_controller_loaded",
