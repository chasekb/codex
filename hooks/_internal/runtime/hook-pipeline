def maybe_close_backlog(state, commit_sha="", verified=None):
    session = state.get("session", {}) if isinstance(state.get("session"), dict) else {}
    candidate_id = text(first(session.get("backlog_task_id"), session.get("backlog_recommendation_id")))
    if not candidate_id:
        return ""
    payload = {}
    if text(commit_sha):
        payload["commit_sha"] = text(commit_sha)
    if verified is not None:
        payload["verified"] = bool(verified)
    rc, out = run_internal("backlog-manager", ["complete", candidate_id], stdin_text=json.dumps(payload))
