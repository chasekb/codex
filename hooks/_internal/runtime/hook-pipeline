#!/usr/bin/env python3
import json
import os
import re
import subprocess
import sys
from datetime import datetime, timezone


def find_repo_root(start: str) -> str:
    cur = os.path.abspath(start)
    while True:
        if (
            os.path.isfile(os.path.join(cur, "hooks.json"))
            and os.path.isdir(os.path.join(cur, "skills"))
            and os.path.isdir(os.path.join(cur, "rules"))
        ):
            return cur
        parent = os.path.dirname(cur)
        if parent == cur:
            raise RuntimeError("repository root not found")
        cur = parent


ROOT = find_repo_root(os.path.dirname(__file__))
STATE_PATH = os.path.join(ROOT, "outputs", "hook-runtime-state.json")
SESSION_PATH = os.path.join(ROOT, "MCP", "memory", "session.json")
TOKEN_DEBUG_PATH = os.path.join(ROOT, "outputs", "hook-token-debug.log")
SKILLS_REGISTRY = os.environ.get("CODEX_SKILLS_REGISTRY") or os.path.join(ROOT, "skills", "registry.yaml")
HOOK_EVENTS_PATH = os.path.join(ROOT, "outputs", "hook-events.log")


def now_iso() -> str:
    return datetime.now(timezone.utc).isoformat().replace("+00:00", "Z")


def to_int(v, default=0):
    try:
        if v is None or v == "":
            return default
        return int(float(str(v)))
    except Exception:
        return default


def to_float(v, default=0.0):
    try:
        if v is None or v == "":
            return default
        return float(str(v))
    except Exception:
        return default


def text(v) -> str:
    if isinstance(v, str):
        return " ".join(v.split()).strip()
    return ""


def first(*values):
    for v in values:
        if isinstance(v, str) and text(v):
            return text(v)
        if v not in (None, "", [], {}):
            return v
    return None


def nested(data, path, default=None):
    cur = data
    for key in path:
        if not isinstance(cur, dict):
            return default
        cur = cur.get(key)
        if cur is None:
            return default
    return cur


def as_dict(value):
    if isinstance(value, dict):
        return value
    if isinstance(value, str):
        try:
            parsed = json.loads(value)
            if isinstance(parsed, dict):
                return parsed
        except Exception:
            pass
    return {}


def load_json(path, default):
    try:
        with open(path, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return default


def save_json(path, data):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2)


