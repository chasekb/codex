        (LEARNINGS_PATH, "# Learnings\n\n"),
        (ERRORS_PATH, "# Errors\n\n"),
        (FEATURE_REQUESTS_PATH, "# Feature Requests\n\n"),
    ):
        if not os.path.exists(path):
            with open(path, "w", encoding="utf-8") as f:
                f.write(header)


