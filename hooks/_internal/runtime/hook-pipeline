def deep_fill_defaults(value, defaults):
    if isinstance(defaults, dict):
        if not isinstance(value, dict):
            value = {}
        merged = {}
        for k, dv in defaults.items():
            merged[k] = deep_fill_defaults(value.get(k), dv)
        return merged
    if isinstance(defaults, list):
        return value if isinstance(value, list) else []
    return value if isinstance(value, type(defaults)) else defaults


def resolve_output_contract(workflow: str) -> str:
    pipeline_path = os.path.join(ROOT, "workflows", "pipelines", f"{workflow}.yaml")
    if os.path.isfile(pipeline_path):
        with open(pipeline_path, "r", encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if line.startswith("output_contract:"):
                    contract = text(line.split(":", 1)[1])
                    if contract:
                        return contract

    normalized = workflow.replace("-", "_").strip()
    return normalized or workflow


def resolve_skills_registry():
    if os.path.isfile(SKILLS_REGISTRY):
        return SKILLS_REGISTRY
    fallback = os.path.expanduser("~/.agents/skills/registry.yaml")
    if os.path.isfile(fallback):
        return fallback
    return SKILLS_REGISTRY


def load_state():
    default = default_state()
    state = load_json(STATE_PATH, default)
    return deep_fill_defaults(state, default)


def run_internal(script_name, args=None, stdin_text=None):
    args = args or []
    script = resolve_internal_script(script_name)
    proc = subprocess.run(
        ["/bin/bash", script, *args],
        input=stdin_text,
        capture_output=True,
        text=True,
        check=False,
        cwd=ROOT,
    )
    out = (proc.stdout or "") + (proc.stderr or "")
    return proc.returncode, out


def resolve_internal_script(script_name):
    if os.path.isabs(script_name) and os.path.isfile(script_name):
        return script_name

    if os.path.sep in script_name:
        candidate = os.path.join(ROOT, script_name)
        if os.path.isfile(candidate):
            return candidate

    internal_root = os.path.join(ROOT, "hooks", "_internal")
    candidate_dirs = (
        "",
        "routing",
        "memory",
        "metrics",
        "output",
        "logging",
        "bootstrap",
        "runtime",
    )
    for subdir in candidate_dirs:
        candidate = os.path.join(internal_root, subdir, script_name) if subdir else os.path.join(internal_root, script_name)
        if os.path.isfile(candidate):
            return candidate

    raise FileNotFoundError(f"internal script not found: {script_name}")


def parse_kv_metric(line, key):
    m = re.search(rf"\b{re.escape(key)}=([0-9]+)", line)
    return int(m.group(1)) if m else 0


def apply_memory_metrics(state, output):
    for line in output.splitlines():
        if line.startswith("memory:metrics"):
            state["metrics"]["memory_write_count"] += parse_kv_metric(line, "writes")
            state["metrics"]["memory_dedup_count"] += parse_kv_metric(line, "dedups")


def extract_paths(tool_input):
    paths = []
    if isinstance(tool_input, dict):
        for key in (
            "path",
            "file_path",
            "target_file",
            "sourcePath",
            "destinationPath",
            "source_path",
            "destination_path",
            "filePath",
        ):
            value = tool_input.get(key)
            if isinstance(value, str) and text(value):
                paths.append(text(value))
        for key in ("paths", "files"):
            value = tool_input.get(key)
            if isinstance(value, list):
                paths.extend([text(v) for v in value if isinstance(v, str) and text(v)])
    return sorted(set(paths))


def update_session_memory(state):
    session = load_json(
        SESSION_PATH,
        {
            "version": 1,
            "max_bytes": 2048,
            "task": {
                "objective": "",
                "constraints": [],
                "active_files": [],
                "latest_decisions": [],
                "blockers": [],
            },
            "updated_at": "",
        },
    )
    task = session.get("task") if isinstance(session.get("task"), dict) else {}
    task["objective"] = state["session"].get("objective", "")
    task["active_files"] = state.get("files_touched", [])[:12]
    session["task"] = task
    session["updated_at"] = now_iso()
    save_json(SESSION_PATH, session)


def add_files(state, paths):
    if not paths:
        return
    merged = set(state.get("files_touched", []))
    merged.update(paths)
    state["files_touched"] = sorted(merged)[:100]


def add_tool(state, tool_name):
    if not isinstance(tool_name, str) or not text(tool_name):
        return
    used = set(state.get("tools_used", []))
    used.add(text(tool_name))
    state["tools_used"] = sorted(used)
    state["counters"]["tools"] = len(state["tools_used"])


def write_memory(state, record_type, scope, tags_csv, content, source="hook-pipeline", confidence="0.8", ttl_days="30"):
    if not text(content):
        return
    _, out = run_internal(
        "write-memory",
        [record_type, scope, tags_csv, text(content)[:220], source, str(confidence), str(ttl_days), "MCP/memory"],
    )
    apply_memory_metrics(state, out)
    return out


def parse_memory_load_metrics(output):
    loaded = 0
    chars = 0
    results = []
    for line in output.splitlines():
        if line.startswith("{") and not results:
            try:
                parsed = json.loads(line)
                if isinstance(parsed, dict):
                    loaded = to_int(parsed.get("memory_loaded", loaded))
                    chars = to_int(parsed.get("chars", chars))
                    maybe_results = parsed.get("results", [])
                    if isinstance(maybe_results, list):
                        results = maybe_results
            except Exception:
                pass
        if line.startswith("memory:metrics"):
            loaded = parse_kv_metric(line, "loaded")
            chars = parse_kv_metric(line, "chars")
    return loaded, chars, results


def parse_compact_kept(output):
    kept = 0
    for line in output.splitlines():
        if line.startswith("memory:metrics"):
            kept = parse_kv_metric(line, "compact_kept")
    return kept


def parse_skill_loaded_chars(output):
    for line in output.splitlines():
        if line.startswith("skill:metrics"):
            return parse_kv_metric(line, "loaded_chars")
    return 0


def format_event_line(event_name, hook_name, workflow="", skill="", stage="", status="", tool=""):
    ts = now_iso()
    fields = [
        f"{ts}",
        f"hook={hook_name}",
        f"event={event_name}",
    ]
    if stage:
        fields.append(f"stage={stage}")
    if status:
        fields.append(f"status={status}")
    if workflow:
        fields.append(f"workflow={workflow}")
    if skill:
        fields.append(f"skill={skill}")
    if tool:
        fields.append(f"tool={tool}")
    return " ".join(fields)


def append_event_log(event_name, hook_name, workflow="", skill="", stage="", status="", tool=""):
    os.makedirs(os.path.dirname(HOOK_EVENTS_PATH), exist_ok=True)
    with open(HOOK_EVENTS_PATH, "a", encoding="utf-8") as f:
        f.write(format_event_line(event_name, hook_name, workflow, skill, stage, status, tool) + "\n")


SEARCH_TOOL_NAMES = {
    "web_search",
    "news_search",
    "image_search",
    "video_search",
    "resolve-library-id",
    "get-library-docs",
}


def normalize_tool_name(tool_name):
    return text(tool_name).lower().replace(".", "_").replace("-", "_")


def is_search_tool(tool_name):
    normalized = normalize_tool_name(tool_name)
    return normalized in {name.replace("-", "_") for name in SEARCH_TOOL_NAMES} or "search" in normalized


def tokenize_words(value):
    if not isinstance(value, str):
        value = text(value)
    return [part for part in re.split(r"[^a-z0-9]+", value.lower()) if len(part) > 2]


def extract_search_query(tool_name, tool_input, payload):
    tool_dict = as_dict(tool_input)
    payload_dict = payload if isinstance(payload, dict) else {}
    normalized = normalize_tool_name(tool_name)

    keys = [
        "query",
        "q",
        "prompt",
        "topic",
        "name",
        "library",
        "library_id",
        "libraryid",
        "library_name",
        "libraryname",
        "url",
    ]
    if "get_library_docs" in normalized or "resolve_library_id" in normalized:
        keys = [
            "query",
            "q",
            "prompt",
            "topic",
            "name",
            "library",
            "library_id",
            "libraryid",
            "library_name",
            "libraryname",
        ]

    candidates = [tool_dict, payload_dict]
    for candidate in candidates:
        for key in keys:
            value = candidate.get(key)
            if isinstance(value, str) and text(value):
                return text(value)
        if len(candidate) == 1:
            only = next(iter(candidate.values()))
            if isinstance(only, str) and text(only):
                return text(only)

    return ""


def summarize_search_sources(response):
    if isinstance(response, (dict, list)):
        data = response
    elif isinstance(response, str):
        try:
            parsed = json.loads(response)
            data = parsed if isinstance(parsed, (dict, list)) else {}
        except Exception:
            data = {}
    else:
        data = as_dict(response)
    candidates = []

    def add_item(item):
        if len(candidates) >= 5:
            return
        if isinstance(item, dict):
            parts = []
            for key in ("title", "name", "id"):
                value = item.get(key)
                if isinstance(value, str) and text(value):
                    parts.append(text(value))
                    break
            for key in ("url", "href", "link"):
                value = item.get(key)
                if isinstance(value, str) and text(value):
                    parts.append(text(value))
                    break
            for key in ("snippet", "summary", "description", "content", "text"):
                value = item.get(key)
                if isinstance(value, str) and text(value):
                    parts.append(text(value)[:180])
                    break
            if not parts:
                scalar = first(*[item.get(k) for k in item.keys()])
                if isinstance(scalar, str) and text(scalar):
                    parts.append(text(scalar)[:180])
            summary = " | ".join(parts)
            if summary and summary not in candidates:
                candidates.append(summary)
        elif isinstance(item, str) and text(item):
            summary = text(item)[:180]
            if summary not in candidates:
                candidates.append(summary)

    if isinstance(data, dict):
        for key in ("results", "items", "sources", "documents", "hits", "pages"):
            value = data.get(key)
            if isinstance(value, list):
                for item in value:
                    add_item(item)
            elif isinstance(value, dict):
                add_item(value)

        for key in ("result", "source", "document", "answer"):
            value = data.get(key)
            if isinstance(value, list):
                for item in value:
                    add_item(item)
            elif isinstance(value, dict):
                add_item(value)

        if not candidates:
            for key in ("title", "name", "url", "link", "summary", "content", "text"):
                value = data.get(key)
                if isinstance(value, str) and text(value):
                    add_item(value)

    elif isinstance(data, list):
        for item in data:
            add_item(item)

    return candidates


def search_reuse_hits(memory_results, objective):
    objective_terms = set(tokenize_words(objective))
    if not objective_terms:
        return 0

    hits = 0
    for record in memory_results:
        if not isinstance(record, dict):
            continue
        tags = {str(tag).lower() for tag in record.get("tags", []) if isinstance(tag, str)}
        content = str(record.get("content_1line", ""))
        content_terms = set(tokenize_words(content))
        if "search" not in tags and not content.lower().startswith("search"):
            continue
        if objective_terms & content_terms:
            hits += 1
    return hits


def pending_searches(state):
    session = state.get("session") if isinstance(state.get("session"), dict) else {}
    pending = session.get("pending_searches", [])
    return pending if isinstance(pending, list) else []


def set_pending_searches(state, items):
    session = state.get("session") if isinstance(state.get("session"), dict) else {}
    session["pending_searches"] = items if isinstance(items, list) else []
    state["session"] = session


def store_pending_search(state, tool_name, query):
    if not text(query):
        return
    pending = pending_searches(state)
    pending.append({
        "tool_name": text(tool_name),
        "query": text(query)[:220],
    })
    set_pending_searches(state, pending[-8:])


def claim_pending_search(state, tool_name):
    pending = pending_searches(state)
    if not pending:
        return {}
    normalized = normalize_tool_name(tool_name)
    for index, item in enumerate(pending):
        item_name = normalize_tool_name(item.get("tool_name", ""))
        if not item_name or item_name == normalized or item_name in normalized or normalized in item_name:
            pending.pop(index)
            set_pending_searches(state, pending)
            return item
    item = pending.pop(0)
    set_pending_searches(state, pending)
    return item


def compact_search_provenance(tool_name, query, sources, reuse_hit):
    query = text(query)[:120] or "n/a"
    source_list = [text(source)[:120] for source in sources if text(source)]
    accepted = source_list[:1] if source_list else []
    source_summary = "; ".join(source_list[:3]) if source_list else "none"
    accepted_summary = "; ".join(accepted) if accepted else "none"
    return (
        f"search tool={text(tool_name)} query={query} "
        f"sources={source_summary} accepted={accepted_summary} reuse_hit={int(bool(reuse_hit))}"
    )


def usage_from_payload(payload, post, response):
    candidates = [
        post.get("usage") if isinstance(post, dict) else None,
        payload.get("usage") if isinstance(payload, dict) else None,
        nested(post, ["result", "usage"]) if isinstance(post, dict) else None,
        nested(payload, ["result", "usage"]) if isinstance(payload, dict) else None,
        response.get("usage") if isinstance(response, dict) else None,
        nested(response, ["result", "usage"]) if isinstance(response, dict) else None,
        post.get("tokenUsage") if isinstance(post, dict) else None,
        payload.get("tokenUsage") if isinstance(payload, dict) else None,
        response.get("tokenUsage") if isinstance(response, dict) else None,
        nested(post, ["metrics", "usage"]) if isinstance(post, dict) else None,
        nested(payload, ["metrics", "usage"]) if isinstance(payload, dict) else None,
        nested(response, ["metrics", "usage"]) if isinstance(response, dict) else None,
    ]
    for c in candidates:
        if isinstance(c, dict):
            return c
    return {}


def parse_usage_tokens(payload, post, response):
    usage = usage_from_payload(payload, post, response)

    input_tokens = to_int(
        first(
            usage.get("inputTokens"),
            usage.get("input_tokens"),
            usage.get("promptTokens"),
            usage.get("prompt_tokens"),
            usage.get("input"),
            post.get("inputTokens") if isinstance(post, dict) else None,
            post.get("input_tokens") if isinstance(post, dict) else None,
            payload.get("inputTokens") if isinstance(payload, dict) else None,
            payload.get("input_tokens") if isinstance(payload, dict) else None,
            payload.get("promptTokens") if isinstance(payload, dict) else None,
            payload.get("prompt_tokens") if isinstance(payload, dict) else None,
            response.get("inputTokens") if isinstance(response, dict) else None,
            response.get("input_tokens") if isinstance(response, dict) else None,
            response.get("promptTokens") if isinstance(response, dict) else None,
            response.get("prompt_tokens") if isinstance(response, dict) else None,
            0,
        )
    )
    output_tokens = to_int(
        first(
            usage.get("outputTokens"),
            usage.get("output_tokens"),
            usage.get("completionTokens"),
            usage.get("completion_tokens"),
            usage.get("output"),
            post.get("outputTokens") if isinstance(post, dict) else None,
            post.get("output_tokens") if isinstance(post, dict) else None,
            payload.get("outputTokens") if isinstance(payload, dict) else None,
            payload.get("output_tokens") if isinstance(payload, dict) else None,
            payload.get("completionTokens") if isinstance(payload, dict) else None,
            payload.get("completion_tokens") if isinstance(payload, dict) else None,
            response.get("outputTokens") if isinstance(response, dict) else None,
            response.get("output_tokens") if isinstance(response, dict) else None,
            response.get("completionTokens") if isinstance(response, dict) else None,
            response.get("completion_tokens") if isinstance(response, dict) else None,
            0,
        )
    )
    total_tokens = to_int(
        first(
            usage.get("totalTokens"),
            usage.get("total_tokens"),
            usage.get("total"),
            post.get("totalTokens") if isinstance(post, dict) else None,
            post.get("total_tokens") if isinstance(post, dict) else None,
            payload.get("totalTokens") if isinstance(payload, dict) else None,
            payload.get("total_tokens") if isinstance(payload, dict) else None,
            response.get("totalTokens") if isinstance(response, dict) else None,
            response.get("total_tokens") if isinstance(response, dict) else None,
            input_tokens + output_tokens,
        ),
        input_tokens + output_tokens,
    )
    return input_tokens, output_tokens, total_tokens, usage


def log_token_debug(tool_name, payload, post, usage, input_tokens, output_tokens, total_tokens):
    os.makedirs(os.path.dirname(TOKEN_DEBUG_PATH), exist_ok=True)
    entry = {
        "ts": now_iso(),
        "tool_name": text(tool_name),
        "input_tokens": input_tokens,
        "output_tokens": output_tokens,
        "total_tokens": total_tokens,
        "payload_keys": sorted(payload.keys()) if isinstance(payload, dict) else [],
        "post_keys": sorted(post.keys()) if isinstance(post, dict) else [],
        "usage_keys": sorted(usage.keys()) if isinstance(usage, dict) else [],
    }
    with open(TOKEN_DEBUG_PATH, "a", encoding="utf-8") as f:
        f.write(json.dumps(entry, separators=(",", ":")) + "\n")


def read_tuning_mode(policy_path):
    try:
        with open(policy_path, "r", encoding="utf-8") as f:
            for line in f:
                s = line.strip()
                if not s or s.startswith("#"):
                    continue
                if s.startswith("mode:"):
                    return s.split(":", 1)[1].strip().lower()
    except Exception:
        pass
    return "observe"


def main():
    hook_name = sys.argv[1] if len(sys.argv) > 1 else "unknown"
    raw = sys.stdin.read()
    try:
        payload = json.loads(raw) if raw.strip() else {}
    except Exception:
        payload = {}

    state = load_state()
    state["updated_at"] = now_iso()
    state["session"]["updated_at"] = state["updated_at"]

    if hook_name in ("TaskStart", "TaskResume"):
        if hook_name == "TaskStart":
            # New task start gets a clean run-state snapshot.
            fresh = default_state()
            state["counters"] = fresh["counters"]
            state["tokens"] = fresh["tokens"]
            state["metrics"] = fresh["metrics"]
            state["tools_used"] = []
            state["files_touched"] = []
            state["session"]["started_at"] = state["updated_at"]

        task_class = first(
            nested(payload, ["task", "class"]),
            nested(payload, [hook_name[0].lower() + hook_name[1:], "taskClass"]),
            payload.get("taskClass"),
            "general",
        )
        confidence = to_float(
            first(
                nested(payload, ["classification", "confidence"]),
                nested(payload, [hook_name[0].lower() + hook_name[1:], "confidence"]),
                payload.get("confidence"),
                0.0,
            ),
            0.0,
        )
        objective = text(
            first(
                nested(payload, ["task", "objective"]),
                nested(payload, [hook_name[0].lower() + hook_name[1:], "prompt"]),
                payload.get("prompt"),
                payload.get("message"),
                state["session"].get("objective", ""),
            )
        )

        keywords = " ".join(objective.split()[:20])
        _, wf_out = run_internal("select-workflow", [str(task_class), f"{confidence:.3f}", keywords, ROOT])
        workflow = text(wf_out.splitlines()[-1] if wf_out.splitlines() else "unknown") or "unknown"
        output_contract = resolve_output_contract(workflow)
        _, skill_out = run_internal("select-skill", [str(task_class), f"{confidence:.3f}", keywords, ROOT])
        skill_lines = [l for l in skill_out.splitlines() if text(l)]
        skill_id = text(skill_lines[-1]) if skill_lines else "tool-minimization"
        skill_fallback = any("fallback=true" in l for l in skill_lines)

        _, load_skill_out = run_internal("load-skill", [skill_id, "metadata", "700", resolve_skills_registry()])
        skill_loaded_chars = parse_skill_loaded_chars(load_skill_out)

        _, load_mem_out = run_internal("load-memory", [str(task_class), keywords, "500", "6", "MCP/memory"])
        mem_loaded, mem_chars, mem_results = parse_memory_load_metrics(load_mem_out)

        state["session"].update(
            {
                "status": "running",
                "started_at": state["session"].get("started_at") or now_iso(),
                "hook_name": hook_name,
                "task_class": str(task_class),
                "workflow": workflow,
                "output_contract": output_contract,
                "skill_id": skill_id,
                "confidence": confidence,
                "objective": objective,
            }
        )
        state["metrics"]["memory_loaded"] = mem_loaded
        state["metrics"]["memory_chars"] = mem_chars
        state["metrics"]["search_reuse_hit"] = search_reuse_hits(mem_results, objective)
        state["metrics"]["skill_loaded_chars"] = skill_loaded_chars
        state["metrics"]["skill_fallback"] = bool(skill_fallback)

        append_event_log(
            "workflow_selected",
            hook_name,
            workflow=workflow,
            skill=skill_id,
            stage="selection",
            status="selected",
        )
        append_event_log(
            "skill_selected",
            hook_name,
            workflow=workflow,
            skill=skill_id,
            stage="selection",
            status="loaded" if skill_loaded_chars else "missing",
        )
        write_memory(
            state,
            "decision",
            "workflow",
            "routing,workflow",
            f"Selected workflow={workflow} class={task_class} confidence={confidence:.2f}",
        )
        write_memory(
            state,
            "decision",
            "workflow",
            "routing,skill",
            f"Selected skill={skill_id} workflow={workflow} class={task_class} confidence={confidence:.2f}",
        )
        update_session_memory(state)

    elif hook_name == "PreToolUse":
        pre = payload.get("preToolUse") if isinstance(payload.get("preToolUse"), dict) else {}
        tool_name = first(
            pre.get("toolName"),
            pre.get("tool_name"),
            payload.get("toolName"),
            payload.get("tool_name"),
            nested(payload, ["tool", "name"]),
            "unknown",
        )
        tool_input = first(
            pre.get("parameters"),
            pre.get("toolInput"),
            pre.get("tool_input"),
            payload.get("parameters"),
            payload.get("toolInput"),
            payload.get("tool_input"),
            {},
        )
        add_tool(state, str(tool_name))
        add_files(state, extract_paths(tool_input))
        state["counters"]["pre_tool"] += 1
        if is_search_tool(tool_name):
            state["metrics"]["search_tool_count"] += 1
            query = extract_search_query(tool_name, tool_input, payload)
            if query:
                state["metrics"]["search_query_count"] += 1
                store_pending_search(state, tool_name, query)
        run_internal("file-logger", stdin_text=raw)
        update_session_memory(state)

    elif hook_name == "PostToolUse":
        post = payload.get("postToolUse") if isinstance(payload.get("postToolUse"), dict) else {}
        response_raw = first(payload.get("tool_response"), payload.get("toolResponse"), post.get("result"), {})
        if isinstance(response_raw, (dict, list)):
            response = response_raw
        elif isinstance(response_raw, str):
            try:
                parsed = json.loads(response_raw)
                response = parsed if isinstance(parsed, (dict, list)) else {}
            except Exception:
                response = {}
        else:
            response = {}
        tool_name = str(
            first(
                post.get("toolName"),
                post.get("tool_name"),
                payload.get("toolName"),
                payload.get("tool_name"),
                nested(payload, ["tool", "name"]),
                response.get("toolName") if isinstance(response, dict) else None,
                response.get("tool_name") if isinstance(response, dict) else None,
                "unknown",
            )
        )
        tool_input = first(
            post.get("parameters"),
            post.get("toolInput"),
            post.get("tool_input"),
            payload.get("parameters"),
            payload.get("toolInput"),
            payload.get("tool_input"),
            {},
        )
        add_tool(state, tool_name)
        state["counters"]["post_tool"] += 1

        input_tokens, output_tokens, total_tokens, usage = parse_usage_tokens(payload, post, response)
        elapsed_ms = to_int(
            first(
                post.get("elapsedMs"),
                post.get("elapsed_ms"),
                payload.get("elapsedMs"),
                payload.get("elapsed_ms"),
                response.get("elapsedMs") if isinstance(response, dict) else None,
                response.get("elapsed_ms") if isinstance(response, dict) else None,
                0,
            )
        )
        retries = to_int(
            first(
                post.get("retries"),
                payload.get("retries"),
                response.get("retries") if isinstance(response, dict) else None,
                0,
            )
        )
        fallbacks = to_int(
            first(
                post.get("fallbacks"),
                payload.get("fallbacks"),
                response.get("fallbacks") if isinstance(response, dict) else None,
                0,
            )
        )

        state["tokens"]["input"] += input_tokens
        state["tokens"]["output"] += output_tokens
        state["tokens"]["total"] += total_tokens
        state["metrics"]["elapsed_ms"] += elapsed_ms
        state["metrics"]["retries"] += retries
        state["metrics"]["fallbacks"] += fallbacks

        if is_search_tool(tool_name):
            pending = claim_pending_search(state, tool_name)
            query = first(pending.get("query") if isinstance(pending, dict) else None, extract_search_query(tool_name, tool_input, payload), "")
            sources = summarize_search_sources(response)
            state["metrics"]["search_source_count"] += len(sources)
            if query or sources:
                before_writes = state["metrics"].get("memory_write_count", 0)
                provenance = compact_search_provenance(tool_name, query, sources, state["metrics"].get("search_reuse_hit", 0))
                write_memory(
                    state,
                    "fact",
                    "research",
                    f"search,{normalize_tool_name(tool_name)},provenance",
                    provenance,
                    source=tool_name,
                    confidence="0.8",
                    ttl_days="30",
                )
                if state["metrics"].get("memory_write_count", 0) > before_writes:
                    state["metrics"]["search_memory_write_count"] += 1

        if input_tokens == 0 and output_tokens == 0 and total_tokens == 0 and isinstance(payload, dict):
            log_token_debug(tool_name, payload, post, usage, input_tokens, output_tokens, total_tokens)

    elif hook_name == "UserPromptSubmit":
        state["counters"]["user_prompt"] += 1
        prompt = text(
            first(
                nested(payload, ["userPromptSubmit", "prompt"]),
                payload.get("prompt"),
                payload.get("message"),
                nested(payload, ["user", "prompt"]),
                "",
            )
        )
        if prompt:
            state["session"]["objective"] = state["session"].get("objective") or prompt[:220]
            write_memory(state, "fact", "session", "prompt,user", prompt[:220], confidence="0.85", ttl_days="14")
            update_session_memory(state)

    elif hook_name == "Notification":
        state["counters"]["notification"] += 1
        level = text(first(nested(payload, ["notification", "level"]), payload.get("level"), "info")).lower()
        message = text(first(nested(payload, ["notification", "message"]), payload.get("message"), payload.get("text"), ""))
        if message and level in {"warning", "warn", "error"}:
            write_memory(state, "fact", "runtime", f"notification,{level}", message[:220], confidence="0.9", ttl_days="21")

    elif hook_name == "PreCompact":
        _, compact_out = run_internal("compact-memory", ["MCP/memory"])
        state["metrics"]["memory_compact_kept"] = parse_compact_kept(compact_out)

    elif hook_name in ("TaskComplete", "TaskCancel"):
        status = "pass" if hook_name == "TaskComplete" else "cancelled"
        if hook_name == "TaskComplete":
            _, compact_out = run_internal("compact-memory", ["MCP/memory"])
            state["metrics"]["memory_compact_kept"] = parse_compact_kept(compact_out)
        state["session"]["status"] = status

        contract_output = text(
            first(
                payload.get("output_file"),
                payload.get("outputFile"),
                nested(payload, ["taskComplete", "output_file"]),
                nested(payload, ["taskComplete", "outputFile"]),
                nested(payload, ["stop", "output_file"]),
                nested(payload, ["stop", "outputFile"]),
                "",
            )
        )
        workflow = str(state["session"].get("workflow", "unknown"))
        output_contract = str(state["session"].get("output_contract", workflow))
        if contract_output:
            output_path = contract_output if os.path.isabs(contract_output) else os.path.join(ROOT, contract_output)
            rc, _ = run_internal(
                "validate-output-contract",
                [output_contract, output_path, "workflows/shared/output-contracts.yaml"],
            )
            state["metrics"]["contract_valid"] = rc == 0
        else:
            state["metrics"]["contract_valid"] = True

        summary = text(first(payload.get("summary"), payload.get("message"), ""))
        if summary:
            write_memory(state, "decision", "session", "completion,status", summary[:220], confidence="0.9", ttl_days="45")

        append_event_log(
            "postrun_summary",
            hook_name,
            workflow=workflow,
            skill=str(state["session"].get("skill_id", "none")),
            stage="postrun",
            status=status,
        )

        run_internal(
            "postrun-metrics",
            [
                str(state["session"].get("task_class", "general")),
                str(state["session"].get("workflow", "unknown")),
                str(state["session"].get("confidence", 0.0)),
                str(state["tokens"].get("input", 0)),
                str(state["tokens"].get("output", 0)),
                str(state["metrics"].get("retries", 0)),
                str(state["metrics"].get("fallbacks", 0)),
                str(state["counters"].get("tools", 0)),
                str(state["metrics"].get("elapsed_ms", 0)),
                status,
                str(state["metrics"].get("contract_valid", False)).lower(),
                str(state["metrics"].get("memory_loaded", 0)),
                str(state["metrics"].get("memory_chars", 0)),
                str(state["metrics"].get("memory_write_count", 0)),
                str(state["metrics"].get("memory_dedup_count", 0)),
                str(state["metrics"].get("memory_compact_kept", 0)),
                str(state["metrics"].get("search_tool_count", 0)),
                str(state["metrics"].get("search_query_count", 0)),
                str(state["metrics"].get("search_source_count", 0)),
                str(state["metrics"].get("search_reuse_hit", 0)),
                str(state["metrics"].get("search_memory_write_count", 0)),
                str(state["session"].get("hook_name", hook_name)),
                "postrun",
                str(state["session"].get("workflow", workflow)),
                str(state["session"].get("skill_id", "none")),
                str(state["metrics"].get("skill_loaded_chars", 0)),
                str(state["metrics"].get("skill_fallback", False)).lower(),
            ],
        )
        run_internal(
            "regression-guard",
            [
                str(state["session"].get("workflow", "unknown")),
                str(state["tokens"].get("total", 0)),
                "10",
                "outputs/token-baselines.csv",
            ],
        )
        run_internal(
            "tune-from-metrics",
            [
                "outputs/token-metrics.csv",
                "MCP/budgets/tuning-policy.yaml",
                "MCP/budgets/token-budgets.yaml",
                "outputs/tuning-proposals.json",
            ],
        )
        run_internal(
            "apply-tuning-canary",
            [
                "outputs/tuning-proposals.json",
                "MCP/budgets/tuning-policy.yaml",
                "MCP/budgets/token-budgets.yaml",
                "outputs/canary-token-budgets.yaml",
                "outputs/canary-report.json",
            ],
        )
        tuning_mode = read_tuning_mode(os.path.join(ROOT, "MCP", "budgets", "tuning-policy.yaml"))
        if tuning_mode in {"auto", "auto_promote", "promote"}:
            run_internal(
                "promote-tuning",
                [
                    "outputs/canary-report.json",
                    "outputs/canary-token-budgets.yaml",
                    "MCP/budgets/token-budgets.yaml",
                    "outputs/tuning-history.csv",
                ],
            )
        update_session_memory(state)

    save_json(STATE_PATH, state)


if __name__ == "__main__":
    main()
