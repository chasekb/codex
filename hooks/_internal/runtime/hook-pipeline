def estimate_prompt_tokens(chars):
    chars = max(0, to_int(chars))
    return max(0, (chars + 3) // 4)


def build_pre_prompt_metrics(objective, memory_chars, learning_chars, failure_chars, playbook_chars, search_hint_chars, skill_chars):
    token_defaults = load_token_defaults()
    objective_chars = len(text(objective))
    context_chars = (
        objective_chars
        + max(0, to_int(memory_chars))
        + max(0, to_int(learning_chars))
        + max(0, to_int(failure_chars))
        + max(0, to_int(playbook_chars))
        + max(0, to_int(search_hint_chars))
        + max(0, to_int(skill_chars))
    )
    est_tokens = estimate_prompt_tokens(context_chars)
    soft_budget = max(1, token_defaults["max_input_tokens"] - token_defaults["reserve_output_tokens"])
    hard_budget = max(soft_budget, token_defaults["hard_abort_tokens"] - token_defaults["reserve_output_tokens"])
    utilization = round(est_tokens / soft_budget, 4) if soft_budget else 0.0
    margin_tokens = soft_budget - est_tokens
    warranted = bool(
        est_tokens >= soft_budget
        or utilization >= 0.85
        or to_int(memory_chars) >= 500
        or to_int(learning_chars) >= 500
        or to_int(failure_chars) >= 400
        or to_int(playbook_chars) >= 500
        or to_int(search_hint_chars) >= 400
        or to_int(skill_chars) >= 700
    )
    return {
        "pre_prompt_budget_soft": soft_budget,
        "pre_prompt_budget_hard": hard_budget,
        "pre_prompt_objective_chars": objective_chars,
        "pre_prompt_context_chars": context_chars,
        "pre_prompt_est_tokens": est_tokens,
        "pre_prompt_utilization": utilization,
        "pre_prompt_margin_tokens": margin_tokens,
        "pre_prompt_adjustment_warranted": warranted,
    }


def prompt_stage_char_cap(remaining_chars, base_chars, floor_chars, weight):
    remaining_chars = max(0, to_int(remaining_chars))
    if remaining_chars <= 0:
        return floor_chars
    cap = int(remaining_chars * weight)
    if cap <= 0:
        cap = floor_chars
    return max(floor_chars, min(base_chars, cap))


def prompt_stage_result_cap(remaining_chars, base_results=6, floor_results=3):
    remaining_chars = max(0, to_int(remaining_chars))
    if remaining_chars <= 400:
        return floor_results
    if remaining_chars <= 900:
        return max(floor_results, base_results - 2)
    if remaining_chars <= 1600:
        return max(floor_results, base_results - 1)
    return base_results


def parse_output_compact_result(output):
    for line in output.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            parsed = json.loads(line)
            if isinstance(parsed, dict):
                return {
                    "removed_count": to_int(parsed.get("removed_count", 0)),
                    "compacted_count": to_int(parsed.get("compacted_count", 0)),
                    "kept_count": to_int(parsed.get("kept_count", 0)),
                    "removed_files": parsed.get("removed_files", []),
                    "compacted_files": parsed.get("compacted_files", []),
                    "outputs_dir": text(parsed.get("outputs_dir", "")),
                    "config": text(parsed.get("config", "")),
                    "prune_unlisted": bool(parsed.get("prune_unlisted", True)),
                }
        except Exception:
            pass
    return {
        "removed_count": 0,
        "compacted_count": 0,
