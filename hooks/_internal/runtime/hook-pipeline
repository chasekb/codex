    "get-library-docs",
}


def normalize_tool_name(tool_name):
    return text(tool_name).lower().replace(".", "_").replace("-", "_")


def is_search_tool(tool_name):
    normalized = normalize_tool_name(tool_name)
    return normalized in {name.replace("-", "_") for name in SEARCH_TOOL_NAMES} or "search" in normalized


def tokenize_words(value):
    if not isinstance(value, str):
        value = text(value)
    return [part for part in re.split(r"[^a-z0-9]+", value.lower()) if len(part) > 2]


def detect_self_improvement_signal(prompt):
    prompt_lc = text(prompt).lower()
    if not prompt_lc:
        return ""
    patterns = [
        ("self-improvement", r"self[- ]?improvement|learning capture|review learnings?|log learnings?|log this to learnings?|extract skill|promote (?:this )?learning|pattern key|recurring pattern|knowledge gap|best practice|lesson learned"),
        ("correction", r"no,? that'?s wrong|actually,? it should be|you'?re wrong|that'?s outdated|correction"),
        ("feature_request", r"missing feature|feature request|can(?:not|'t) do|wish you could|is there a way to"),
    ]
    for label, pattern in patterns:
        if re.search(pattern, prompt_lc):
            return label
    return ""


def detect_backlog_signal(prompt):
    prompt_lc = text(prompt).lower()
    if not prompt_lc:
        return False
    return bool(
        re.search(
            r"\b(backlog|recommendation|recommendations|roadmap|prioritiz|project management|project recommendation|incomplete project|task list|todo list)\b",
            prompt_lc,
        )
    )


def log_backlog_intake(state, prompt, signal_source="user_prompt"):
    prompt_text = text(prompt)
    if not prompt_text:
        return None
    payload = {
        "kind": "recommendation",
        "title": prompt_text[:100],
        "summary": prompt_text[:220],
        "details": prompt_text,
        "source": signal_source,
        "priority": "medium",
        "tags": ["backlog", "recommendation", "project-management"],
    }
    rc, out = run_internal("backlog-manager", ["intake"], stdin_text=json.dumps(payload))
    state["metrics"]["backlog_intake_runs"] += 1
    if rc == 0:
        try:
            for line in out.splitlines():
                line = line.strip()
                if line.startswith("{"):
                    parsed = json.loads(line)
                    if isinstance(parsed, dict) and text(parsed.get("id", "")):
                        state["session"]["backlog_recommendation_id"] = text(parsed.get("id", ""))
