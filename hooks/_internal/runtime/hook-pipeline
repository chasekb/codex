def parse_external_skill_discovery(output):
    report = {}
    for line in output.splitlines():
        line = line.strip()
        if not line:
            continue
        if line.startswith("{") and not report:
            try:
                parsed = json.loads(line)
                if isinstance(parsed, dict):
                    report = parsed
                    continue
            except Exception:
                pass
        if line.startswith("external_skill:"):
            report.setdefault("lines", []).append(line)
    return report


def parse_backlog_metrics(output):
    report = {
        "loaded": 0,
        "open_recommendations": 0,
        "open_tasks": 0,
        "completed_tasks": 0,
    }
    for line in output.splitlines():
        line = line.strip()
        if not line:
            continue
        if line.startswith("{"):
            try:
                parsed = json.loads(line)
                if isinstance(parsed, dict):
                    stats = parsed.get("stats") if isinstance(parsed.get("stats"), dict) else {}
                    report["open_recommendations"] = to_int(stats.get("open_recommendations", report["open_recommendations"]))
                    report["open_tasks"] = to_int(stats.get("open_tasks", report["open_tasks"]))
                    report["completed_tasks"] = to_int(stats.get("completed_tasks", report["completed_tasks"]))
            except Exception:
                pass
        if line.startswith("backlog:metrics"):
            report["loaded"] = 1
            report["open_recommendations"] = parse_kv_metric(line, "open_recommendations")
            report["open_tasks"] = parse_kv_metric(line, "open_tasks")
            report["completed_tasks"] = parse_kv_metric(line, "completed_tasks")
    return report


