lm="$(hooks/_internal/memory/load-memory general "remember fact" 700 6 "$mem")"
echo "$lm" | grep -Fq 'memory:metrics loaded=' && pass load_memory || fail load_memory

cm="$(hooks/_internal/memory/compact-memory "$mem")"
echo "$cm" | grep -Fq 'memory:compact_ok' && pass compact_memory || fail compact_memory

