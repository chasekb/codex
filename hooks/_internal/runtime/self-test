mkdir -p "$mem"
cat > "$mem/session.json" <<'JSON'
{"version":1,"max_bytes":2048,"task":{"objective":"test objective","constraints":[],"active_files":[]},"updated_at":""}
JSON
: > "$mem/facts.jsonl"
: > "$mem/decisions.jsonl"

wm="$(hooks/_internal/memory/write-memory fact session testtag "remember this fact" self-test 0.9 30 "$mem")"
