printf 'orphan\n' > "$outputs_dir/contract-sample.txt"
compact_config="$tmpdir/output-handling.yaml"
cat > "$compact_config" <<'YAML'
compaction:
  enabled: true
  prune_unlisted: true
  keep_files:
    - hook-events.log
    - token-metrics.csv
  line_limits:
    hook-events.log: 3
  row_limits:
    token-metrics.csv: 2
YAML
hooks/_internal/output/compact-outputs "$outputs_dir" "$compact_config" >/dev/null && pass compact_outputs || fail compact_outputs
[[ ! -f "$outputs_dir/contract-sample.txt" ]] && pass compact_outputs_prune || fail compact_outputs_prune
