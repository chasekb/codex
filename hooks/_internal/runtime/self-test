#!/usr/bin/env bash
set -euo pipefail

find_repo_root() {
  local dir="$1"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/hooks.json" && -d "$dir/skills" && -d "$dir/rules" ]]; then
      printf '%s\n' "$dir"
      return 0
    fi
    dir="$(dirname -- "$dir")"
  done
  return 1
}

ROOT="$(find_repo_root "$(cd -- "$(dirname -- "$0")" && pwd)")"
cd "$ROOT"

tmpdir="$(mktemp -d /tmp/hooks-internal-self-test.XXXXXX)"
trap 'rm -rf "$tmpdir"' EXIT

pass() { printf 'PASS %s\n' "$1"; }
fail() { printf 'FAIL %s\n' "$1"; exit 1; }

