contracts:
  debug_rca:
    required:
      - findings
      - root_cause
  ci_triage:
    required:
      - failure_summary
      - likely_cause
      - evidence
      - next_action
      - confidence
  release_publish:
    required:
      - objective
      - files_changed
      - validation
      - publish_result
      - rollback_note
  dependency_maintenance:
    required:
      - current_state
      - candidate_updates
      - risk_assessment
      - validation_plan
      - status
YAML
out="$tmpdir/out.txt"
printf 'findings: yes\nroot_cause: yes\n' > "$out"
hooks/_internal/output/validate-output-contract debug-rca "$out" "$contracts" >/dev/null && pass validate_output_contract || fail validate_output_contract

out_ci="$tmpdir/out-ci.txt"
printf 'failure_summary: yes\nlikely_cause: yes\nevidence: yes\nnext_action: yes\nconfidence: yes\n' > "$out_ci"
hooks/_internal/output/validate-output-contract ci-triage "$out_ci" "$contracts" >/dev/null && pass validate_output_contract_ci_triage || fail validate_output_contract_ci_triage

out_release="$tmpdir/out-release.txt"
printf 'objective: yes\nfiles_changed: yes\nvalidation: yes\npublish_result: yes\nrollback_note: yes\n' > "$out_release"
hooks/_internal/output/validate-output-contract release-publish "$out_release" "$contracts" >/dev/null && pass validate_output_contract_release_publish || fail validate_output_contract_release_publish

out_deps="$tmpdir/out-deps.txt"
printf 'current_state: yes\ncandidate_updates: yes\nrisk_assessment: yes\nvalidation_plan: yes\nstatus: yes\n' > "$out_deps"
hooks/_internal/output/validate-output-contract dependency-maintenance "$out_deps" "$contracts" >/dev/null && pass validate_output_contract_dependency_maintenance || fail validate_output_contract_dependency_maintenance

