skill_release_artifact="$(hooks/_internal/routing/select-skill general 0.9 "release publish" "$repo")"
echo "$skill_release_artifact" | tail -n1 | grep -qx 'release-publish' && pass select_skill_release_artifact || fail select_skill_release_artifact

