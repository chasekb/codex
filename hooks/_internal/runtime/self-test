tail -n1 "$outputs_dir/token-metrics.csv" | grep -Fq '4,four' && pass compact_outputs_rows || fail compact_outputs_rows

python3 hooks/_internal/runtime/hook-pipeline PreCompact <<'JSON' >/dev/null && pass hook_pipeline_precompact_compact || fail hook_pipeline_precompact_compact
{}
JSON
grep -Fq 'event=outputs_compacted' outputs/hook-events.log && pass outputs_compact_event_logged || fail outputs_compact_event_logged

hooks/_internal/metrics/postrun-metrics debug debug-rca 0.9 10 5 0 0 3 120 pass true 2 200 1 0 2 4 5 6 7 8 TaskStart postrun debug-rca plan-verify-execute 600 false 3800 11800 12 242 61 0.0161 3739 false >/dev/null && pass postrun_metrics || fail postrun_metrics
head -n1 outputs/token-metrics.csv | grep -Fq 'pre_prompt_budget_soft,pre_prompt_budget_hard,pre_prompt_objective_chars,pre_prompt_context_chars,pre_prompt_est_tokens,pre_prompt_utilization,pre_prompt_margin_tokens,pre_prompt_adjustment_warranted' && pass postrun_metrics_header || fail postrun_metrics_header

base="$tmpdir/baseline.csv"
hooks/_internal/metrics/regression-guard debug-rca 100 10 "$base" >/dev/null && pass regression_bootstrap || fail regression_bootstrap
hooks/_internal/metrics/regression-guard debug-rca 105 10 "$base" >/dev/null && pass regression_ok || fail regression_ok
set +e
hooks/_internal/metrics/regression-guard debug-rca 200 10 "$base" >/dev/null 2>&1
rc=$?
set -e
[[ $rc -eq 1 ]] && pass regression_fail || fail regression_fail

